{
  "title": "BoobaStudio",
  "description": "BoobaStudio is a personal Foundry VTT module fork that brings AI-assisted text, image, audio, scene, token, and document tools directly into your world. Configure a provider you control, keep keys client-scoped, and use the existing Foundry-native workflows to create content for your tabletop adventures.",
  "version": "2.2.101",
  "url": "https://github.com/DeadSpace161/boobastudio",
