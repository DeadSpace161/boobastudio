<div class="cibola8-vector-store scrollable">
  {{!-- Header --}}
  <header class="cibola8-vector-header">
    <div class="cibola8-vector-header-icon">
      <i class="fas fa-database"></i>
    </div>
    <div class="cibola8-vector-header-content">
      <h2>{{localize 'cibola8.vector.uploadTitle'}}</h2>
      <p class="cibola8-text-muted">{{localize 'cibola8.vector.headerDescription'}}</p>
    </div>
  </header>

  {{!-- Info Card --}}
  <div class="cibola8-info-card">
    <div class="cibola8-info-card-header">
      <i class="fas fa-lightbulb"></i>
      <span>{{localize 'cibola8.vector.howItWorks'}}</span>
    </div>
    <div class="cibola8-info-card-body">
      <ul class="cibola8-feature-list">
        <li>
          <i class="fas fa-search"></i>
          <span>{{localize 'cibola8.vector.featureSearch'}}</span>
        </li>
        <li>
          <i class="fas fa-brain"></i>
          <span>{{localize 'cibola8.vector.featureContext'}}</span>
        </li>
        <li>
          <i class="fas fa-comments"></i>
          <span>{{localize 'cibola8.vector.featureThreads'}}</span>
        </li>
      </ul>
      <p class="cibola8-text-muted cibola8-info-note">
        <i class="fas fa-info-circle"></i>
        {{localize 'cibola8.vector.manaNote'}}
      </p>
    </div>
  </div>

  {{!-- Vector Stores Section --}}
  <section class="cibola8-vector-section">
    <div class="cibola8-section-header">
      <h3><i class="fas fa-folder-open"></i> {{localize 'cibola8.vector.yourStores'}}</h3>
    </div>
    
    {{#if userInfo.alive}}
    <div class='storages'>
      <div class="cibola8-empty-state">
        <i class="fas fa-spinner fa-spin fa-2x"></i>
        <p>{{localize 'cibola8.loading'}}</p>
      </div>
    </div>
    {{else}}
      {{{patreon}}}
    {{/if}}
  </section>
</div>