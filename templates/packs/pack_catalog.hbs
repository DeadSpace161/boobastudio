{{!-- Pack Library Catalog - shows tag-grouped sections with search --}}
<div class="pack-catalog">
  {{!-- Top bar - search + My Packs toggle --}}
  <div class="gallery-filters pack-catalog-search">
    <div class="gallery-search">
      <i class="fas fa-search"></i>
      <input type="text" name="packSearch"
             placeholder="{{localize 'boobastudio.packs.searchPlaceholder'}}"
             data-tooltip="boobastudio.packs.searchHint"
             value="{{searchQuery}}" />
    </div>
    <button class="boobastudio-btn boobastudio-btn--secondary boobastudio-btn--sm"
            data-action="showMyPacks" data-tooltip="boobastudio.packs.myPacksHint" type="button">
      <i class="fas fa-folder-open"></i>
      {{localize 'boobastudio.packs.myPacks'}}
    </button>
  </div>

  {{!-- Featured packs row --}}
  {{#if featured.length}}
  <div class="pack-tag-group pack-tag-group--featured">
    <h3 class="pack-tag-group-title">
      <i class="fas fa-star"></i>
      {{localize 'boobastudio.packs.featured'}}
      <span class="boobastudio-text-muted">({{featured.length}})</span>
    </h3>
    <div class="gallery-masonry pack-grid">
      {{#each featured}}
        {{> modules/boobastudio/templates/packs/pack_card.hbs this}}
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Tag-grouped rows --}}
  {{#each groups}}
  <div class="pack-tag-group" data-tag="{{this.tag}}">
    <h3 class="pack-tag-group-title">
      <i class="fas fa-tag"></i>
      {{this.tag}}
      <span class="boobastudio-text-muted">({{this.packs.length}})</span>
    </h3>
    <div class="gallery-masonry pack-grid">
      {{#each this.packs}}
        {{> modules/boobastudio/templates/packs/pack_card.hbs this}}
      {{/each}}
    </div>
  </div>
  {{/each}}

  {{!-- Empty state - reuses gallery-empty --}}
  {{#unless hasAnyPacks}}
  <div class="gallery-empty">
    <i class="fas fa-box-open"></i>
    <p>{{localize 'boobastudio.packs.noPacks'}}</p>
  </div>
  {{/unless}}
</div>
