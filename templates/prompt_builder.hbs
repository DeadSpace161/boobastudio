<div>
  <div class="flexrow">
    <textarea class="stretch textarea boobastudio-prompt-textarea" name="command" placeholder="{{localize 'boobastudio.promptbuilderhint'}}"></textarea>
  </div>
  <div class="form-group">
    <label>{{localize "boobastudio.count"}} <i class="fas fa-exclamation-triangle"></i></label>
    <div class="form-fields">
      <range-picker name="count" value="2" min="2" max="6" step="1"></range-picker>
    </div>
    <p class="hint">{{localize "boobastudio.countHint"}}</p>
  </div>

</div>