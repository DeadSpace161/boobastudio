<section class="tab standard-form scrollable boobastudio-localizer-tab {{tabs.translations.cssClass}}" data-tab="translations" data-group="{{tabs.translations.group}}">
  <div class="boobastudio boobastudio-translations">

    {{!-- Header --}}
    <header class="boobastudio-localizer-header">
      <div class="boobastudio-localizer-header-icon">
        <i class="fas fa-file-alt"></i>
      </div>
      <div class="boobastudio-localizer-header-content">
        <h2>{{localize 'boobastudio.Localizer.translations'}}</h2>
        <p>{{localize 'boobastudio.Localizer.descriptionTranslations'}}</p>
      </div>
    </header>

    {{!-- Warning Notice --}}
    <div class="boobastudio-notice boobastudio-notice--warning">
      <i class="fas fa-exclamation-triangle"></i>
      <span>{{localize 'boobastudio.Localizer.warning'}}</span>
    </div>

    {{#unless userInfo.alive}}
      {{{patreon}}}
    {{/unless}}

    {{!-- Supported Languages Section --}}
    <div class="boobastudio-section-card">
      <div class="boobastudio-section-card-header">
        <i class="fas fa-globe"></i>
        <span>{{localize 'boobastudio.Localizer.supported_translations'}}</span>
      </div>
      <div class="boobastudio-section-card-body">
        <div class="boobastudio-language-tags supportedLanguages">
          {{{translator.supportedLanguages}}}
        </div>

        <div class="boobastudio-add-language-form">
          <div class="boobastudio-form-group boobastudio-form-group--inline">
            <label class="boobastudio-form-label">
              <i class="fas fa-plus-circle"></i>
              {{localize 'boobastudio.AiTranslator.language'}}
            </label>
            <select name="newLanguage" class="boobastudio-select">
              {{selectOptions translator.languages selected=translator.language labelAttr="name" valueAttr="lang" sort=true}}
            </select>
            <button type="button" class="boobastudio-btn boobastudio-btn--primary" data-action="saveLang" data-tooltip="{{localize 'boobastudio.Localizer.addLanguage'}}">
              <i class="fas fa-save"></i>
              {{localize 'boobastudio.save'}}
            </button>
          </div>
          <p class="boobastudio-hint">
            <i class="fas fa-info-circle"></i>
            {{localize 'boobastudio.Localizer.addLanguage'}}
          </p>
        </div>
      </div>
    </div>

    {{!-- Language Files Section --}}
    <div class="boobastudio-section-card">
      <div class="boobastudio-section-card-header">
        <i class="fas fa-folder-open"></i>
        <span>{{localize 'boobastudio.Localizer.langFiles'}}</span>
        <a class="boobastudio-btn boobastudio-btn--icon addOwnLangFile" data-tooltip="{{localize 'boobastudio.tooltip.addOwnLangFile'}}">
          <i class="fas fa-upload"></i>
        </a>
      </div>
      <div class="boobastudio-section-card-body">
        {{!-- Table Header --}}
        <div class="boobastudio-translation-table-header">
          <div class="boobastudio-translation-col boobastudio-translation-col--module">{{localize 'boobastudio.Localizer.modul'}}</div>
          <div class="boobastudio-translation-col boobastudio-translation-col--lang">{{localize 'boobastudio.AiTranslator.language'}}</div>
          <div class="boobastudio-translation-col boobastudio-translation-col--status">{{localize 'boobastudio.Localizer.active'}}</div>
          <div class="boobastudio-translation-col boobastudio-translation-col--actions"></div>
        </div>

        {{!-- Translation Files List --}}
        <div class="boobastudio-translation-list translationfiles">
          {{#each translationData.files as |file|}}
            {{> modules/boobastudio/templates/localizer/translationentry.hbs file=file}}
          {{/each}}

          {{#unless translationData.files.length}}
          <div class="boobastudio-empty-state boobastudio-empty-state--small">
            <i class="fas fa-file-circle-question"></i>
            <p>{{localize 'boobastudio.noEntries'}}</p>
          </div>
          {{/unless}}
        </div>
      </div>
    </div>

  </div>
</section>