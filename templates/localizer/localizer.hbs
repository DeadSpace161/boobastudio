<section class="tab standard-form scrollable boobastudio-localizer-tab {{tabs.localizer.cssClass}}" data-tab="localizer" data-group="{{tabs.localizer.group}}">
  <div class="boobastudio boobastudio-localizer">

    {{!-- Header --}}
    <header class="boobastudio-localizer-header">
      <div class="boobastudio-localizer-header-icon">
        <i class="fas fa-language"></i>
      </div>
      <div class="boobastudio-localizer-header-content">
        <h2>{{localize 'boobastudio.Localizer.modules'}}</h2>
        <p>{{localize 'boobastudio.Localizer.description'}}</p>
      </div>
    </header>

    {{!-- Warning Notice --}}
    <div class="boobastudio-notice boobastudio-notice--warning">
      <i class="fas fa-exclamation-triangle"></i>
      <span>{{localize 'boobastudio.Localizer.warning'}}</span>
    </div>

    {{#unless userInfo.alive}}
      {{{patreon}}}
    {{/unless}}

    {{!-- Translation Panel --}}
    <div class="boobastudio-localizer-panel">
      {{!-- Module Selection --}}
      <div class="boobastudio-form-group">
        <label class="boobastudio-form-label">
          <i class="fas fa-cube"></i>
          {{localize 'boobastudio.Localizer.modul'}}
        </label>
        <select name="moduleId" class="boobastudio-select">
          {{selectOptions modules selected=selectedModul valueAttr='id' labelAttr='title' sort=true}}
        </select>
      </div>

      {{!-- Translation Flow --}}
      <div class="boobastudio-translation-flow">
        {{!-- Source Panel --}}
        <div class="boobastudio-translation-card boobastudio-translation-card--source">
          <div class="boobastudio-translation-card-header">
            <i class="fas fa-file-import"></i>
            <span>{{localize 'boobastudio.Localizer.source'}}</span>
          </div>
          <div class="boobastudio-translation-card-body">
            <div class="boobastudio-form-group">
              <label class="boobastudio-form-label">{{localize 'boobastudio.AiTranslator.language'}}</label>
              <select name="moduleLanguage" class="boobastudio-select">
                {{selectOptions languages selected=selectedLang valueAttr='lang' labelAttr='name' sort=true}}
              </select>
            </div>
            <div class="boobastudio-translation-card-visual">
              <img src="modules/boobastudio/templates/assets/scroll1.webp" alt="Source" />
            </div>
          </div>
        </div>

        {{!-- Flow Arrow --}}
        <div class="boobastudio-translation-arrow" data-tooltip="{{localize 'boobastudio.Localizer.batchmodeHint'}}">
          <div class="boobastudio-batch-toggle">
            <input type="checkbox" name="batch" id="batch-toggle" value="1" checked />
            <label for="batch-toggle" class="boobastudio-batch-label">
              <i class="fas fa-bolt"></i>
              <span class="boobastudio-batch-info">
                <span class="boobastudio-badge boobastudio-badge--info">{{localize 'boobastudio.Localizer.batch'}}</span>
                <span class="boobastudio-batch-savings">1/2 <span class="manapot"></span></span>
              </span>
            </label>
          </div>
          <i class="fas fa-arrow-right boobastudio-flow-icon"></i>
        </div>

        {{!-- Target Panel --}}
        <div class="boobastudio-translation-card boobastudio-translation-card--target" data-tooltip="{{localize 'boobastudio.AiTranslator.languagehint'}}">
          <div class="boobastudio-translation-card-header">
            <i class="fas fa-file-export"></i>
            <span>{{localize 'boobastudio.Localizer.target'}}</span>
          </div>
          <div class="boobastudio-translation-card-body">
            <div class="boobastudio-form-group">
              <label class="boobastudio-form-label">{{localize 'boobastudio.AiTranslator.language'}}</label>
              <select name="translator.language" class="boobastudio-select">
                {{selectOptions translator.languages selected=translator.language labelAttr='name' valueAttr='lang' sort=true}}
              </select>
            </div>
            <div class="boobastudio-translation-card-visual">
              <img src="modules/boobastudio/templates/assets/scroll2.webp" alt="Target" />
            </div>
          </div>
        </div>
      </div>

      {{!-- Action Section --}}
      {{#if userInfo.alive}}
      <div class="boobastudio-localizer-actions">
        <p class="boobastudio-hint">
          <i class="fas fa-info-circle"></i>
          {{localize 'boobastudio.AiTranslator.waitSomeTime'}}
        </p>
        <button type="button" class="boobastudio-btn boobastudio-btn--primary boobastudio-btn--lg" data-tooltip="{{localize 'boobastudio.spinner'}}" data-action="translate">
          <i class="fas fa-language"></i>
          {{localize 'boobastudio.AiTranslator.title'}}
        </button>
      </div>
      {{/if}}
    </div>

  </div>
</section>