<div class="cibola8-translation-row" data-translationid="{{file.module}}_{{file.lang}}">
  <div class="cibola8-translation-col cibola8-translation-col--module">
    {{#if file.status}}
      <span class="cibola8-text-muted">{{file.module}}</span>
    {{else}}
      <a class="cibola8-link editEntry" data-id="{{file.module}}" data-lang="{{file.lang}}">
        <i class="fas fa-edit"></i>
        {{file.module}}
      </a>
    {{/if}}
  </div>

  <div class="cibola8-translation-col cibola8-translation-col--lang">
    <span class="cibola8-badge cibola8-badge--muted">{{file.lang}}</span>
  </div>

  <div class="cibola8-translation-col cibola8-translation-col--status">
    {{#if file.status}}
      <div class="cibola8-status-indicator cibola8-status-indicator--processing" data-tooltip="{{timeSince file.time}}">
        {{#if file.progress}}
          <div class="cibola8-progress-mini">
            <div class="cibola8-progress-mini-bar" style="width: {{file.progress}}%"></div>
          </div>
          <span>{{file.progress}}%</span>
        {{else}}
          <i class="fas fa-clock fa-spin"></i>
          <span>{{file.status}}</span>
        {{/if}}
      </div>
    {{else}}
      <label class="cibola8-toggle">
        <input type="checkbox" class="enableTranslation" data-id="{{file.module}}" data-lang="{{file.lang}}" name="{{file.module}}_{{file.lang}}" {{checked file.active}} />
        <span class="cibola8-toggle-slider"></span>
      </label>
    {{/if}}
  </div>

  <div class="cibola8-translation-col cibola8-translation-col--actions">
    <a class="cibola8-btn cibola8-btn--icon cibola8-btn--danger removeEntry" data-tooltip="{{localize 'cibola8.delete'}}" data-id="{{file.module}}" data-lang="{{file.lang}}">
      <i class="fas fa-trash"></i>
    </a>
  </div>
</div>