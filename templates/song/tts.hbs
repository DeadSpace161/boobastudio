<section class="tab standard-form scrollable {{tabs.tts.cssClass}}" data-tab="tts"
    data-group="{{tabs.tts.group}}">
    <div class="flexcol" style="flex: 1">
        <div class="boobastudio-intro-text boobastudio-mb-3">
            <i class="fas fa-microphone boobastudio-intro-icon"></i>
            <span>{{localize 'boobastudio.musicgen.ttsdescription'}}</span>
        </div>

        {{#unless userInfo.alive}}
            {{{patreon}}}
        {{else}}

        <div class="flexrow align-child-top stretch" style="gap: 0.75rem;">
            <div class="flexcol stretch" style="flex: 1;">
                <fieldset class="flexcol promptblock stretch boobastudio-glass">
                    <legend><i class="fas fa-comment-dots"></i> {{localize 'boobastudio.prompt'}}</legend>
                    <div class="flexrow">
                        <div class="form-group">
                            <label>{{localize 'boobastudio.fields.model'}}</label>
                            <div class="form-fields">
                                <select name="ttschoice">
                                    {{selectOptions ttsmodels selected=ttschoice}}
                                </select>
                            </div>
                        </div>
                        <div class="manaheader">{{{ttsmanaHtml}}}</div>
                    </div>
                    <div class="ttsmodelcontainer">
                        {{{modelFields}}}
                    </div>
                </fieldset>

                {{!-- Player block - only visible when audio is generated --}}
                <fieldset class="flexcol playerblock hidden stretch boobastudio-player-panel boobastudio-glass">
                    <legend class="songNameLegend"><i class="fas fa-play-circle"></i></legend>
                    <div class="flexrow boobastudio-player-controls">
                        <div></div>
                        <button type="button" data-tooltip="boobastudio.musicgen.saveToPlaylist" data-action="saveToPlaylist" class="boobastudio-btn boobastudio-btn--icon boobastudio-btn--success boobastudio-btn--sm"><i class="fas fa-save"></i></button>
                        <button type="button" data-tooltip="boobastudio.musicgen.hideSongs" data-action="hideSongs" class="boobastudio-btn boobastudio-btn--icon boobastudio-btn--danger boobastudio-btn--sm"><i class="fas fa-times"></i></button>
                    </div>

                    <div class="flexrow align-child-top boobastudio-player-content">
                        <div class="showImage boobastudio-album-art">
                            <div class="showImageContainer">
                                <img/>
                                <div class="iContainer boobastudio-loading-overlay">
                                    <div class="boobastudio-spinner boobastudio-spinner-lg"></div>
                                </div>
                            </div>
                            <audio controls class="boobastudio-audio-player"></audio>
                            <p class="boobastudio-hint boobastudio-hint--compact">{{localize 'boobastudio.musicgen.previewNote'}}</p>
                        </div>
                        <div class="showLyrics scrollable boobastudio-lyrics-text" style="flex: 1; max-height: 200px;"></div>
                    </div>
                </fieldset>
            </div>

            <fieldset class="flexcol imageHistory ttshistory hidden boobastudio-history-sidebar">
                <legend><i class="fas fa-clock-rotate-left"></i> {{localize 'boobastudio.history'}}</legend>
                <div class="boobastudio-history-grid"></div>
            </fieldset>
        </div>
        {{/unless}}
    </div>
</section>