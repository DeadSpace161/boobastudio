<section class="tab standard-form scrollable {{tabs.generator.cssClass}}" data-tab="generator"
    data-group="{{tabs.generator.group}}">
    <div class="flexcol" style="flex: 1">
        <div class="boobastudio-intro-text boobastudio-mb-3">
            <i class="fas fa-music boobastudio-intro-icon"></i>
            <span>{{localize 'boobastudio.musicgen.description'}}</span>
        </div>

        {{#unless userInfo.alive}}
            {{{patreon}}}
        {{else}}
        <div class="flexrow align-child-top stretch" style="gap: 0.75rem;">
            <div class="flexcol stretch" style="flex: 1;">
        <fieldset class="flexcol playerblock hidden stretch boobastudio-player-panel boobastudio-glass">
            <legend class="songNameLegend"><i class="fas fa-play-circle"></i></legend>
            <div class="flexrow boobastudio-player-controls">
                <div></div>
                <button data-tooltip="boobastudio.musicgen.saveToPlaylist" data-action="saveToPlaylist" class="imgControls boobastudiobutton smallbutton boobastudio-btn boobastudio-btn--primary"><i class="fas fa-save"></i></button>
                <button type="button" data-tooltip="boobastudio.musicgen.hideSongs" data-action="hideSongs" class="imgControls smallbutton"><i class="fas fa-times"></i></button>
            </div>

            <div class="flexrow align-child-top boobastudio-player-content">
                <div class="showImage boobastudio-album-art">
                    <div class="showImageContainer">
                        <img/>
                        <div class="iContainer boobastudio-loading-overlay">
                            <div class="boobastudio-spinner boobastudio-spinner-lg"></div>
                        </div>
                    </div>
                    <audio controls class="boobastudio-audio-player"></audio>
                    <p class="hint boobastudio-hint">{{localize 'boobastudio.musicgen.previewNote'}}</p>
                </div>
                <div class="boobastudio-lyrics-container">
                    <div class="showLyrics scrollable boobastudio-lyrics-text" style="max-height: 420px;"></div>
                </div>
            </div>
        </fieldset>

        <fieldset class="flexcol promptblock stretch boobastudio-prompt-panel">
            <legend><i class="fas fa-music"></i> {{localize 'boobastudio.prompt'}}</legend>
            {{#if songModels.length}}
            <div class="form-group">
                <label>{{localize 'boobastudio.musicgen.model'}}</label>
                <div class="form-fields">
                    <select name="songmodel">
                        {{#each songModels}}
                        <option value="{{this.id}}" data-per-length="{{this.perLength}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                        {{/each}}
                    </select>
                </div>
            </div>
            {{/if}}
            <div class="form-group">
                <label>{{localize 'boobastudio.musicgen.songtitle'}}</label>
                <div class="form-fields">
                    <input type="text" name="songtitle" placeholder="{{localize 'boobastudio.musicgen.songtitlehint'}}" class="boobastudio-input-enhanced">
                </div>
            </div>
            <div class="form-group stretch">
                <label>{{localize 'boobastudio.musicgen.lyrics'}}
                    <button type="button" class="smallbutton boobastudiobutton" data-action="generateLyrics" data-tooltip="boobastudio.musicgen.generateLyricsHint"><i class="fas fa-wand-magic-sparkles"></i></button>
                </label>
                <div class="form-fields">
                    <textarea name="lyrics" placeholder="{{localize 'boobastudio.musicgen.lyricshint'}}" class="boobastudio-textarea-enhanced"></textarea>
                </div>
            </div>
             <div class="form-group" data-tooltip="boobastudio.musicgen.createLyricsHint">
                <label for="createLyricscb">{{localize 'boobastudio.musicgen.createLyrics'}}</label>
                <input type="checkbox" id="createLyricscb" name="createLyrics" checked>
            </div>
            <div class="form-group">
                <label>{{localize 'boobastudio.musicgen.style'}}
                    <button type="button" class="smallbutton boobastudiobutton" data-action="enhanceStyle" data-tooltip="boobastudio.improvisePromptHint"><i class="fas fa-wrench"></i></button>
                </label>
                <div class="form-fields">
                    <textarea name="style" class="smallone boobastudio-textarea-enhanced" placeholder="{{localize 'boobastudio.musicgen.stylehint'}}"></textarea>
                </div>
            </div>
            <div class="form-group" data-tooltip="boobastudio.musicgen.instrumentalhint">
                <label for="instrumentalcb">{{localize 'boobastudio.musicgen.instrumental'}}</label>
                <input type="checkbox" id="instrumentalcb" name="instrumental">
            </div>
            <details class="boobastudio-advanced-panel" open>
                <summary><i class="fas fa-sliders-h"></i> {{localize 'boobastudio.musicgen.advanced'}}</summary>
                <div class="songmodelcontainer">
                    {{{songModelFields}}}
                </div>
            </details>
            <div class="flexcol boobastudio-mt-2 boobastudio-mb-2 boobastudio-price-preview-panel">
                <div class="manaheader songpricepreview">{{{songPricePreview}}}</div>
                <p class="hint boobastudio-hint"><i class="fas fa-clock"></i> {{localize 'boobastudio.musicgen.timeHint'}}</p>
            </div>
            <div class="flexrow mt-2">
                <button type="button" class="boobastudio-btn boobastudio-btn--primary boobastudio-btn--lg" data-action="generate" data-tooltip="boobastudio.spinner">
                    <i class="fas fa-wand-magic-sparkles"></i>
                    {{localize 'boobastudio.musicgen.title'}}
                </button>
            </div>
        </fieldset>
            </div>

            <fieldset class="flexcol imageHistory songhistory hidden boobastudio-history-sidebar">
                <legend><i class="fas fa-clock-rotate-left"></i> {{localize 'boobastudio.history'}}</legend>
                <div class="boobastudio-history-grid"></div>
            </fieldset>
        </div>
        {{/unless}}

    </div>

</section>