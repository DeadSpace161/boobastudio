<div class="boobastudio-onboarding">
  {{!-- Scrollable Content --}}
  <div class="boobastudio-onboarding__content">

    {{!-- Important Disclaimer - Uses design system notice --}}
    <section class="boobastudio-notice boobastudio-notice--warning boobastudio-notice--compact">
      <i class="boobastudio-notice__icon fas fa-exclamation-triangle"></i>
      <div class="boobastudio-notice__content">
        <h3 class="boobastudio-notice__title">{{localize "boobastudio.onboarding.welcome.disclaimer.title"}}</h3>
        <ul class="boobastudio-notice__text" style="margin: 0; padding-left: 1.25rem;">
          <li>{{{localize "boobastudio.onboarding.welcome.disclaimer.ai"}}}</li>
          <li>{{{localize "boobastudio.onboarding.welcome.disclaimer.external"}}}</li>
          <li>{{{localize "boobastudio.onboarding.welcome.disclaimer.subscription"}}}</li>
        </ul>
      </div>
    </section>

    {{!-- Hero Section --}}
    <section class="boobastudio-onboarding__hero">
      <img
        class="boobastudio-onboarding__logo"
        src="modules/boobastudio/templates/assets/cibolacoin.webp"
        alt="Cibola 8"
      />
      <h1 class="boobastudio-onboarding__title">{{localize "boobastudio.onboarding.welcome.title"}}</h1>
      <p class="boobastudio-onboarding__tagline">{{localize "boobastudio.onboarding.welcome.tagline"}}</p>

      <div class="boobastudio-onboarding__hero-actions">
        <button
          type="button"
          class="boobastudio-btn boobastudio-btn--accent boobastudio-btn--draggable"
          draggable="true"
          data-tooltip="{{localize 'boobastudio.onboarding.welcome.dragToHotbarHint'}}"
        >
          <i class="fas fa-grip"></i>
          {{localize "boobastudio.onboarding.welcome.dragToHotbar"}}
        </button>
        <button
          type="button"
          class="boobastudio-btn boobastudio-btn--secondary"
          data-action="openSettings"
        >
          <i class="fas fa-cog"></i>
          {{localize "boobastudio.onboarding.welcome.openSettings"}}
        </button>
        <button
          type="button"
          class="boobastudio-btn boobastudio-btn--secondary"
          data-action="openApp"
          data-tooltip="{{localize 'boobastudio.onboarding.welcome.openAppHint'}}"
        >
          <i class="fas fa-external-link-alt"></i>
          {{localize "boobastudio.onboarding.welcome.openApp"}}
        </button>
      </div>
    </section>

    {{!-- Features Section --}}
    <section class="boobastudio-onboarding__features">
      <h2 class="boobastudio-onboarding__section-title">{{localize "boobastudio.onboarding.featuresTitle"}}</h2>
      <div class="boobastudio-onboarding__feature-grid">
        {{#each features}}
        <div
          class="boobastudio-onboarding__feature-card"
          data-action="openFeature"
          data-feature="{{this.id}}"
          data-tooltip-class="boobastudio-feature-tooltip"
          data-tooltip="<div class='boobastudio-feature-tooltip'><div class='boobastudio-feature-tooltip__title'>{{this.title}}</div><div class='boobastudio-feature-tooltip__desc'>{{this.description}}</div><div class='boobastudio-feature-tooltip__hint'>{{localize 'boobastudio.onboarding.welcome.clickToTry'}}</div></div>"
        >
          <button
            type="button"
            class="boobastudio-onboarding__feature-info"
            data-action="openDocs"
            data-feature="{{this.id}}"
            data-tooltip="boobastudio.onboarding.welcome.resources.docs"
          >
            <i class="fas fa-circle-info"></i>
          </button>
          <i class="boobastudio-onboarding__feature-icon fas {{this.icon}}"></i>
          <span class="boobastudio-onboarding__feature-title">{{this.title}}</span>
        </div>
        {{/each}}
      </div>
    </section>

    {{!-- Finding Cibola Section --}}
    <section class="boobastudio-onboarding__find-cibola">
      <h2 class="boobastudio-onboarding__section-title">{{localize "boobastudio.onboarding.welcome.findCibola.title"}}</h2>
      <div class="boobastudio-onboarding__find-cibola-card">
        <div class="boobastudio-onboarding__find-cibola-icon">
          <i class="cib8-icon icon-boobastudio"></i>
        </div>
        <div class="boobastudio-onboarding__find-cibola-body">
          <p class="boobastudio-onboarding__find-cibola-desc">{{localize "boobastudio.onboarding.welcome.findCibola.desc"}}</p>
          <ul class="boobastudio-onboarding__find-cibola-list">
            <li><i class="fas fa-window-maximize"></i> {{localize "boobastudio.onboarding.welcome.findCibola.contextMenu"}}</li>
            <li><i class="fas fa-pen-fancy"></i> {{localize "boobastudio.onboarding.welcome.findCibola.editorToolbar"}}</li>
            <li><i class="fas fa-map"></i> {{localize "boobastudio.onboarding.welcome.findCibola.sceneControls"}}</li>
          </ul>
        </div>
      </div>
    </section>

    {{!-- Connection Modes Section --}}
    <section class="boobastudio-onboarding__modes">
      <h2 class="boobastudio-onboarding__section-title">{{localize "boobastudio.onboarding.modesTitle"}}</h2>
      <div class="boobastudio-onboarding__mode-grid">
        {{!-- Cibola Backend --}}
        <div class="boobastudio-onboarding__mode-card {{#if backendConnected}}boobastudio-onboarding__mode-card--connected{{/if}}">
          <div class="boobastudio-onboarding__mode-header">
            <i class="fas fa-cloud"></i>
            <span>{{localize "boobastudio.onboarding.welcome.modes.backendTitle"}}</span>
            {{#if backendConnected}}
            <span class="boobastudio-badge boobastudio-badge--success boobastudio-badge--sm">
              <i class="fas fa-check-circle"></i>
              {{localize "boobastudio.onboarding.welcome.modes.connected"}}
            </span>
            {{/if}}
          </div>
          <p class="boobastudio-onboarding__mode-desc">
            {{localize "boobastudio.onboarding.welcome.modes.backendDesc"}}
          </p>
          {{#unless backendConnected}}
          <div class="boobastudio-onboarding__mode-actions">
            <button
              type="button"
              class="boobastudio-btn boobastudio-btn--accent boobastudio-btn--sm"
              data-action="connectPatreon"
            >
              <i class="fab fa-patreon"></i>
              {{localize "boobastudio.connect.button"}}
            </button>
            <button
              type="button"
              class="boobastudio-btn boobastudio-btn--secondary boobastudio-btn--sm"
              data-action="setupToken"
            >
              <i class="fas fa-keyboard"></i>
              {{localize "boobastudio.connect.manualEntry"}}
            </button>
          </div>
          {{/unless}}
        </div>

        {{!-- Client-Only Mode --}}
        <div class="boobastudio-onboarding__mode-card">
          <div class="boobastudio-onboarding__mode-header">
            <i class="fas fa-key"></i>
            <span>{{localize "boobastudio.onboarding.welcome.modes.clientTitle"}}</span>
          </div>
          <p class="boobastudio-onboarding__mode-desc">{{localize "boobastudio.onboarding.welcome.modes.clientDesc"}}</p>
          <button
            type="button"
            class="boobastudio-btn boobastudio-btn--secondary boobastudio-btn--sm"
            data-action="configureClientOnly"
          >
            {{localize "boobastudio.onboarding.welcome.modes.clientAction"}}
          </button>
        </div>
      </div>
    </section>

    {{!-- Gallery Preview Section --}}
    {{#if galleryImages.length}}
    <section class="boobastudio-onboarding__gallery">
      <h2 class="boobastudio-onboarding__section-title">{{localize "boobastudio.onboarding.welcome.gallery.title"}}</h2>
      <div class="boobastudio-onboarding__gallery-grid">
        {{#each galleryImages}}
        <div
          class="boobastudio-onboarding__gallery-item"
          data-action="viewImage"
          data-url="{{this.url}}"
          data-tooltip="{{this.prompt}}"
        >
          <img src="{{this.thumbnail}}" alt="Generated image" loading="lazy" />
        </div>
        {{/each}}
        <div
          class="boobastudio-onboarding__gallery-more"
          data-action="openGallery"
        >
          <span>{{localize "boobastudio.onboarding.welcome.gallery.viewAll"}}</span>
        </div>
      </div>
    </section>
    {{/if}}

    {{!-- Resources Section --}}
    <section class="boobastudio-onboarding__resources">
      <div class="boobastudio-onboarding__resource-row">
        <button
          type="button"
          class="boobastudio-btn boobastudio-btn--ghost boobastudio-btn--sm"
          data-action="openDocumentation"
        >
          <i class="fas fa-book"></i>
          {{localize "boobastudio.onboarding.welcome.resources.docs"}}
        </button>
        <a
          href="{{urls.faq}}"
          target="_blank"
          class="boobastudio-btn boobastudio-btn--ghost boobastudio-btn--sm"
          data-resource="faq"
        >
          <i class="fas fa-question-circle"></i>
          {{localize "boobastudio.onboarding.welcome.resources.faq"}}
        </a>
        <a
          href="{{urls.discord}}"
          target="_blank"
          class="boobastudio-btn boobastudio-btn--ghost boobastudio-btn--sm"
          data-resource="discord"
        >
          <i class="fab fa-discord"></i>
          {{localize "boobastudio.onboarding.welcome.resources.discord"}}
        </a>
        <a
          href="{{urls.patreon}}"
          target="_blank"
          class="boobastudio-btn boobastudio-btn--ghost boobastudio-btn--sm"
          data-resource="patreon"
        >
          <i class="fab fa-patreon"></i>
          {{localize "boobastudio.onboarding.welcome.resources.patreon"}}
        </a>
      </div>
    </section>

  </div>

  {{!-- Footer --}}
  <footer class="boobastudio-onboarding__footer">
    <label class="boobastudio-onboarding__dont-show">
      <input type="checkbox" name="dontShowAgain" {{#if dontShowAgain}}checked{{/if}} />
      {{localize "boobastudio.onboarding.welcome.dontShowAgain"}}
    </label>
    <button
      type="button"
      class="boobastudio-btn boobastudio-btn--accent"
      data-action="getStarted"
    >
      {{localize "boobastudio.onboarding.welcome.getStarted"}}
    </button>
  </footer>
</div>
