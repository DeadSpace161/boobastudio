<section class="tab standard-form scrollable {{tabs.browser.cssClass}}" data-tab="browser"
    data-group="{{tabs.browser.group}}">

    <p class="cibola8-text-muted cibola8-intro-text cibola8-mb-3">
        <i class="fas fa-images cibola8-intro-icon"></i>
        {{localize 'cibola8.AiBrowser.description'}}
    </p>
    
    {{!-- Filter Section --}}
    <div class="gallery-filters filterSection cibola8-tabs cibola8-tabs--inline">
        <button data-action="changeFilter" data-filter="own" type="button" 
                class="cibola8-tab {{ifThen (eq currenttab 'own') 'active' ''}}">
            <i class="fas fa-image"></i> 
            {{localize 'cibola8.AiBrowser.myimages'}}
        </button>
        {{#unless hasCallback}}
        <button data-action="changeFilter" data-filter="song" type="button" 
                class="cibola8-tab {{ifThen (eq currenttab 'song') 'active' ''}}">
            <i class="fas fa-music"></i> 
            {{localize 'cibola8.AiBrowser.mysongs'}}
        </button>
        {{/unless}}
        <span class="cibola8-tab-divider"></span>
        <button data-action="changeFilter" data-filter="all" type="button" 
                class="cibola8-tab {{ifThen (eq currenttab 'all') 'active' ''}}">
            <i class="fas fa-globe"></i> 
            {{localize 'cibola8.AiBrowser.publicGallery'}}
        </button>
        <button data-action="changeFilter" data-filter="packs" type="button" 
                class="cibola8-tab {{ifThen (eq currenttab 'packs') 'active' ''}}"
                data-tooltip="cibola8.packs.titleHint">
            <i class="fas fa-box-open"></i> 
            {{localize 'cibola8.packs.title'}}
        </button>
    </div>

    {{!-- Search Section --}}
    <div class="gallery-filters searchFilter cibola8-search-bar">        
        <div class="gallery-search semanticSearch cibola8-search-input {{ifThen (eq currenttab 'all') '' 'hidden'}}">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="{{localize 'cibola8.AiBrowser.search'}}..."/>
        </div>
        <div class="gallery-search categorySearch cibola8-search-input">
            <i class="fas fa-filter"></i>
            <select name="category">
                {{selectOptions imageCategories localize=true}}
            </select>
        </div>
    </div>

    {{!-- Gallery Content --}}
    <div class="flexcol stretch">
        {{#if canUseGallery}}
        <div class="elementslist flexcol">
            <div class="gallery-masonry elements">
                {{!-- Items loaded dynamically --}}
            </div>
            <div class="gallery-loader mainloader cibola8-loader-container">
                <div class="cibola8-spinner cibola8-spinner-lg"></div>
                <span class="cibola8-loader-text">{{localize 'cibola8.loading'}}</span>
            </div>
        </div>
        {{else}}
            {{{patreon}}}
        {{/if}}

        {{!-- Detail View Controls --}}
        <div class="detailControls hidden">
            <div class="gallery-detail-view cibola8-glass">
                <div class="detail-actions">
                    {{#if hasCallback}}
                    <button class="cibola8-btn cibola8-btn--primary" data-action="pickGalleryImage" data-tooltip="cibola8.tooltip.yourchoice" type="button">
                        <i class="fas fa-check"></i>
                        {{localize 'cibola8.tooltip.yourchoice'}}
                    </button>
                    {{/if}}
                    <button class="cibola8-btn cibola8-btn--secondary" data-action="closeDetails" type="button">
                        <i class="fas fa-arrow-left"></i>
                        {{localize 'cibola8.radialMenu.back'}}
                    </button>
                </div>            
            </div>
        </div>

        {{!-- Item Control Panel --}}
        <fieldset class="detailControls hidden cibola8-control-panel">
            <legend><i class="fas fa-sliders-h"></i> {{localize 'cibola8.AiBrowser.control'}}</legend>
            <div class="detail-actions cibola8-action-bar">
                <button class="cibola8-btn cibola8-btn--danger imageonly" data-action="deletePrediction" data-tooltip="cibola8.tooltip.deletePrediction" type="button">
                    <i class="fas fa-trash"></i>
                </button>
                <div class="gallery-audio-player songonly">
                    <audio controls>
                        <source type="audio/mpeg">
                    </audio>
                </div>
                <button class="cibola8-btn cibola8-btn--secondary imageonly" data-action="togglePublic" type="button">
                    <i class="fas fa-bullhorn"></i> 
                    {{localize 'cibola8.tooltip.togglePublic'}}
                </button>
                <button class="cibola8-btn cibola8-btn--secondary" data-action="copyUrl" data-tooltip="cibola8.tooltip.copyUrl" type="button">
                    <i class="fas fa-copy"></i>
                </button>
            </div>
        </fieldset>
    </div>
</section>