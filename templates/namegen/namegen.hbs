{{!-- Name Generator - BoobaStudio Design System --}}
<div class="boobastudio-namegen scrollable" data-part="config">
    {{!-- Header Section --}}
    <div class="boobastudio-namegen__header">
        <div class="boobastudio-intro-text">
            <i class="fas fa-signature boobastudio-intro-icon"></i>
            <span>{{localize 'boobastudio.namegen.description'}}</span>
        </div>
        <div class="boobastudio-hint">
            <i class="fas fa-lightbulb"></i>
            <span>{{localize 'boobastudio.namegen.hint'}}</span>
        </div>
    </div>

    {{#if tokengroups}}
    <div class="boobastudio-namegen__groups">
        {{#each tokengroups as |group|}}
        <fieldset class="boobastudio-namegen__group boobastudio-glass tokenGroup">
            <legend class="boobastudio-legend actorOpener handcursor" data-uuid="{{group.actor.uuid}}" data-tooltip="{{localize 'boobastudio.namegen.openActor'}}">
                <i class="fas fa-users"></i>
                <span>{{group.actor.name}}</span>
                <span class="boobastudio-legend__count">({{group.tokens.length}})</span>
            </legend>

            {{!-- Prompt Row for Group --}}
            <div class="boobastudio-prompt-section">
                <div class="boobastudio-prompt-header">
                    <label data-tooltip="{{localize 'boobastudio.namegen.promptTooltip'}}">
                        <i class="fas fa-wand-magic-sparkles"></i>
                        {{localize 'boobastudio.prompt'}}
                    </label>
                    <div class="boobastudio-prompt-actions">
                        <button type="button" class="boobastudio-tool-btn boobastudio-tool-btn--primary" data-action="rollGroup" data-tooltip="{{localize 'boobastudio.namegen.generateAll'}}">
                            <i class="fas fa-dice"></i>
                            <span>{{localize 'boobastudio.namegen.all'}}</span>
                        </button>
                        <button type="button" class="boobastudio-tool-btn boobastudio-tool-btn--success" data-action="saveGroup" data-tooltip="{{localize 'boobastudio.namegen.saveAll'}}">
                            <i class="fas fa-save"></i>
                            <span>{{localize 'boobastudio.save'}}</span>
                        </button>
                    </div>
                </div>
                <textarea
                    name="{{group.actor.uuid}}"
                    data-dtype="String"
                    placeholder="{{localize 'boobastudio.namegen.promptplaceholder'}}"
                    class="boobastudio-textarea"
                    rows="2"
                ></textarea>
            </div>

            {{!-- Token List --}}
            <div class="boobastudio-namegen__tokens">
                {{#each group.tokens as |token|}}
                <div class="boobastudio-namegen__token boobastudio-list-item tokenrow" data-uuid="{{token.uuid}}">
                    {{!-- Token Portrait --}}
                    <div class="boobastudio-portrait boobastudio-portrait--md boobastudio-portrait--clickable actorOpener" data-uuid="{{token.uuid}}" data-tooltip="{{localize 'boobastudio.namegen.openToken'}}">
                        <img src="{{token.texture.src}}" alt="{{token.name}}" />
                    </div>

                    {{!-- Gender Selection --}}
                    <div class="boobastudio-namegen__genders" data-tooltip="{{localize 'boobastudio.namegen.genderTooltip'}}">
                        <label class="boobastudio-toggle-btn boobastudio-toggle-btn--female">
                            <input class="genders" name="female" type="checkbox" value="w" checked />
                            <i class="fas fa-venus"></i>
                        </label>
                        <label class="boobastudio-toggle-btn boobastudio-toggle-btn--male">
                            <input class="genders" name="male" type="checkbox" value="m" checked />
                            <i class="fas fa-mars"></i>
                        </label>
                    </div>

                    {{!-- Name Input & Actions --}}
                    <div class="boobastudio-namegen__name-section">
                        <button type="button" class="boobastudio-tool-btn boobastudio-tool-btn--primary boobastudio-tool-btn--icon" data-action="rollName" data-tooltip="{{localize 'boobastudio.namegen.generate'}}">
                            <i class="fas fa-dice"></i>
                        </button>
                        <input
                            type="text"
                            name="name_{{token.uuid}}"
                            value="{{token.name}}"
                            data-dtype="String"
                            class="boobastudio-input"
                            placeholder="{{localize 'boobastudio.namegen.namePlaceholder'}}"
                        />
                        <button type="button" class="boobastudio-tool-btn boobastudio-tool-btn--success boobastudio-tool-btn--icon" data-action="saveName" data-tooltip="{{localize 'boobastudio.namegen.saveName'}}">
                            <i class="fas fa-save"></i>
                        </button>
                    </div>
                </div>
                {{/each}}
            </div>
        </fieldset>
        {{/each}}
    </div>
    {{else}}
    {{!-- Empty State --}}
    <div class="boobastudio-namegen__empty boobastudio-empty-state">
        <div class="boobastudio-empty-state__icon">
            <i class="fas fa-users-slash"></i>
        </div>
        <h3 class="boobastudio-empty-state__title">{{localize 'boobastudio.namegen.no_groups'}}</h3>
        <p class="boobastudio-empty-state__description">{{localize 'boobastudio.namegen.no_groups_hint'}}</p>
        <div class="boobastudio-empty-state__help boobastudio-hint">
            <i class="fas fa-info-circle"></i>
            <span>{{localize 'boobastudio.namegen.no_groups_help'}}</span>
        </div>
    </div>
    {{/if}}
</div>
</div>