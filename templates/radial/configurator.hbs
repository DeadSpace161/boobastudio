<div class="boobastudio-radial-config scrollable">
    {{!-- Header --}}
    <header class="boobastudio-radial-header">
        <div class="boobastudio-radial-header-icon">
            <i class="fas fa-circle-nodes"></i>
        </div>
        <div class="boobastudio-radial-header-content">
            <h2>{{localize 'boobastudio.settings.radialconfig'}}</h2>
            <p class="boobastudio-text-muted">{{localize 'boobastudio.radialMenu.headerDescription'}}</p>
        </div>
    </header>

    {{!-- Action Bar --}}
    <div class="boobastudio-radial-actions">
        <button type="button" class="boobastudio-btn-action boobastudio-btn-action--primary" data-tooltip="{{localize 'boobastudio.radialMenu.test'}}" data-action="testMenu">
            <i class="fas fa-play"></i>
            <span>{{localize 'boobastudio.radialMenu.test'}}</span>
        </button>
        <button type="button" class="boobastudio-btn-action boobastudio-btn-action--success" data-tooltip="{{localize 'boobastudio.radialMenu.addSection'}}" data-action="addSection">
            <i class="fas fa-plus"></i>
            <span>{{localize 'boobastudio.radialMenu.addSection'}}</span>
        </button>
        <button type="button" class="boobastudio-btn-action dragMe" data-tooltip="{{localize 'boobastudio.radialMenu.dragMe'}}">
            <i class="fas fa-grip"></i>
            <span>{{localize 'boobastudio.radialMenu.dragMe'}}</span>
        </button>
    </div>

    {{!-- Info Card --}}
    <div class="boobastudio-info-card boobastudio-info-card--compact">
        <div class="boobastudio-info-card-header">
            <i class="fas fa-lightbulb"></i>
            <span>{{localize 'boobastudio.radialMenu.howToUse'}}</span>
        </div>
        <div class="boobastudio-info-card-body">
            <ul class="boobastudio-feature-list boobastudio-feature-list--compact">
                <li>
                    <i class="fas fa-hand-pointer"></i>
                    <span>{{localize 'boobastudio.radialMenu.tipDragDrop'}}</span>
                </li>
                <li>
                    <i class="fas fa-folder-plus"></i>
                    <span>{{localize 'boobastudio.radialMenu.tipSections'}}</span>
                </li>
                <li>
                    <i class="fas fa-image"></i>
                    <span>{{localize 'boobastudio.radialMenu.tipCustomize'}}</span>
                </li>
            </ul>
        </div>
    </div>

    {{!-- Menu Items Section --}}
    <section class="boobastudio-radial-section">
        <div class="boobastudio-section-header">
            <h3><i class="fas fa-list"></i> {{localize 'boobastudio.radialMenu.menuItems'}}</h3>
        </div>

        <div class="boobastudio-radial-items">
            {{#each baseButtons as |button|}}
                {{> 'modules/boobastudio/templates/radial/submenu.hbs' button=button}}
            {{/each}}

            {{#unless baseButtons.length}}
            <div class="boobastudio-empty-state">
                <i class="fas fa-circle-nodes fa-2x"></i>
                <p>{{localize 'boobastudio.radialMenu.noItems'}}</p>
                <span class="boobastudio-text-muted">{{localize 'boobastudio.radialMenu.noItemsHint'}}</span>
            </div>
            {{/unless}}
        </div>
    </section>
</div>