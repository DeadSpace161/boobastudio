<div class="cibola8-radial-config scrollable">
    {{!-- Header --}}
    <header class="cibola8-radial-header">
        <div class="cibola8-radial-header-icon">
            <i class="fas fa-circle-nodes"></i>
        </div>
        <div class="cibola8-radial-header-content">
            <h2>{{localize 'cibola8.settings.radialconfig'}}</h2>
            <p class="cibola8-text-muted">{{localize 'cibola8.radialMenu.headerDescription'}}</p>
        </div>
    </header>

    {{!-- Action Bar --}}
    <div class="cibola8-radial-actions">
        <button type="button" class="cibola8-btn-action cibola8-btn-action--primary" data-tooltip="{{localize 'cibola8.radialMenu.test'}}" data-action="testMenu">
            <i class="fas fa-play"></i>
            <span>{{localize 'cibola8.radialMenu.test'}}</span>
        </button>
        <button type="button" class="cibola8-btn-action cibola8-btn-action--success" data-tooltip="{{localize 'cibola8.radialMenu.addSection'}}" data-action="addSection">
            <i class="fas fa-plus"></i>
            <span>{{localize 'cibola8.radialMenu.addSection'}}</span>
        </button>
        <button type="button" class="cibola8-btn-action dragMe" data-tooltip="{{localize 'cibola8.radialMenu.dragMe'}}">
            <i class="fas fa-grip"></i>
            <span>{{localize 'cibola8.radialMenu.dragMe'}}</span>
        </button>
    </div>

    {{!-- Info Card --}}
    <div class="cibola8-info-card cibola8-info-card--compact">
        <div class="cibola8-info-card-header">
            <i class="fas fa-lightbulb"></i>
            <span>{{localize 'cibola8.radialMenu.howToUse'}}</span>
        </div>
        <div class="cibola8-info-card-body">
            <ul class="cibola8-feature-list cibola8-feature-list--compact">
                <li>
                    <i class="fas fa-hand-pointer"></i>
                    <span>{{localize 'cibola8.radialMenu.tipDragDrop'}}</span>
                </li>
                <li>
                    <i class="fas fa-folder-plus"></i>
                    <span>{{localize 'cibola8.radialMenu.tipSections'}}</span>
                </li>
                <li>
                    <i class="fas fa-image"></i>
                    <span>{{localize 'cibola8.radialMenu.tipCustomize'}}</span>
                </li>
            </ul>
        </div>
    </div>

    {{!-- Menu Items Section --}}
    <section class="cibola8-radial-section">
        <div class="cibola8-section-header">
            <h3><i class="fas fa-list"></i> {{localize 'cibola8.radialMenu.menuItems'}}</h3>
        </div>
        
        <div class="cibola8-radial-items">
            {{#each baseButtons as |button|}}
                {{> 'modules/cibola8/templates/radial/submenu.hbs' button=button}}
            {{/each}}
            
            {{#unless baseButtons.length}}
            <div class="cibola8-empty-state">
                <i class="fas fa-circle-nodes fa-2x"></i>
                <p>{{localize 'cibola8.radialMenu.noItems'}}</p>
                <span class="cibola8-text-muted">{{localize 'cibola8.radialMenu.noItemsHint'}}</span>
            </div>
            {{/unless}}
        </div>
    </section>
</div>