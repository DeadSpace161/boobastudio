<form class="standard-form scrollable">
  {{!-- ================================================================== --}}
  {{!-- Cibola API Key — primary connection method                         --}}
  {{!-- ================================================================== --}}
  <fieldset class="cibola8-glass cibola8-mb-3">
    <legend><i class="fas fa-key"></i> {{localize "cibola8.settings.apikey"}}</legend>

    <div class="cibola8-hint cibola8-mb-2">
      <i class="fas fa-info-circle"></i>
      {{localize "cibola8.settings.apikeyHint"}}
    </div>

    {{!-- One-click Patreon connect --}}
    <button type="button" class="cibola8-btn cibola8-btn--accent cibola8-btn--full" data-action="connectPatreon">
      <i class="fab fa-patreon"></i> {{localize "cibola8.connect.button"}}
    </button>
    <p class="cibola8-hint cibola8-mt-1 cibola8-mb-2">
      <i class="fas fa-bolt"></i> {{localize "cibola8.connect.hint"}}
    </p>

    {{!-- Manual key entry (collapsed) --}}
    <details class="cibola8-manual-key-section">
      <summary class="cibola8-btn cibola8-btn--ghost cibola8-btn--sm cibola8-btn--full">
        <i class="fas fa-keyboard"></i> {{localize "cibola8.connect.manualEntry"}}
      </summary>

      <div class="cibola8-link-list cibola8-mb-2 cibola8-mt-1">
        <a href="{{urls.patreon}}" target="_blank" class="cibola8-link-item">
          <i class="fab fa-patreon"></i> {{localize "cibola8.token.getKeyPatreon"}}
        </a>
        <a href="{{urls.app}}" target="_blank" class="cibola8-link-item">
          <i class="fas fa-globe"></i> {{localize "cibola8.token.getKeyApp"}}
        </a>
      </div>

      <div class="form-group cibola8-form-group-animated">
        <label><i class="fas fa-ticket"></i> {{localize "cibola8.settings.apikey"}}</label>
        <div class="form-fields">
          {{#if revealed}}
            <input name="apikey" type="text" value="{{tokenValue}}" placeholder="{{localize 'cibola8.settings.apiKeyPlaceholder'}}" class="cibola8-input" />
          {{else}}
            <input name="apikey" type="password" value="{{tokenValue}}" placeholder="{{localize 'cibola8.settings.apiKeyPlaceholder'}}" autocomplete="off" class="cibola8-input" />
          {{/if}}
        </div>
      </div>

      <div class="cibola8-action-bar">
        <button type="button" class="cibola8-tool-btn" data-action="toggleReveal" data-tooltip="{{#if revealed}}Hide{{else}}Reveal{{/if}}">
          {{#if revealed}}<i class="fas fa-eye-slash"></i>{{else}}<i class="fas fa-eye"></i>{{/if}}
        </button>
        <button type="button" class="cibola8-tool-btn" data-action="copyToken" {{#unless revealed}}disabled{{/unless}} data-tooltip="cibola8.token.copy">
          <i class="fas fa-copy"></i>
        </button>
        <button type="button" class="cibola8-btn cibola8-btn--primary" data-action="saveapikey">
          <i class="fas fa-save"></i> {{localize "cibola8.save"}}
        </button>
      </div>
    </details>

    <hr class="cibola8-divider" />

    {{!-- Validation --}}
    <div class="form-group cibola8-form-group-animated">
      <label><i class="fas fa-check-circle"></i> {{localize "cibola8.token.validate"}}</label>
      <div class="form-fields cibola8-validation-row">
        <button type="button" class="cibola8-btn cibola8-btn--secondary" data-action="validateToken">
          <i class="fas fa-sync-alt"></i> {{localize "cibola8.token.validate"}}
        </button>
        <span class="cibola8-badge cibola8-badge--lg {{#if (eq status 'valid')}}cibola8-badge--success{{else if (eq status 'invalid')}}cibola8-badge--danger{{else}}cibola8-badge--muted{{/if}}">
          <i class="fas {{#if (eq status 'valid')}}fa-check{{else if (eq status 'invalid')}}fa-times{{else}}fa-question{{/if}}"></i>
          {{statusLabel}}
        </span>
      </div>
      <p class="cibola8-hint mt-1">
        <i class="fas fa-lightbulb"></i> {{localize "cibola8.token.validateHint"}}
      </p>
    </div>
  </fieldset>

  {{!-- ================================================================== --}}
  {{!-- OpenAI API Key — client-only fallback (limited features)           --}}
  {{!-- ================================================================== --}}
  <fieldset class="cibola8-glass cibola8-glass--muted">
    <legend><i class="fas fa-robot"></i> {{localize "cibola8.clientOnly.settings.openaiKey"}}</legend>

    {{!-- Limited-functionality warning --}}
    <div class="cibola8-warning-box cibola8-mb-2">
      <div class="cibola8-warning-icon">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <div class="cibola8-warning-content">
        <p>{{localize "cibola8.clientOnly.settings.limitedWarning"}}</p>
      </div>
    </div>

    <div class="cibola8-hint cibola8-mb-2">
      <i class="fas fa-info-circle"></i>
      {{localize "cibola8.clientOnly.settings.openaiKeyHint"}}
    </div>

    <div class="cibola8-link-list cibola8-mb-2">
      <a href="{{urls.openaiPlatform}}" target="_blank" class="cibola8-link-item">
        <i class="fab fa-openai"></i> {{localize "cibola8.clientOnly.settings.getOpenAIKey"}}
      </a>
    </div>

    <div class="form-group cibola8-form-group-animated">
      <label><i class="fab fa-openai"></i> {{localize "cibola8.clientOnly.settings.openaiKey"}}</label>
      <div class="form-fields">
        {{#if revealed}}
          <input name="openaiApiKey" type="text" value="{{openaiKeyValue}}" placeholder="sk-..." class="cibola8-input" />
        {{else}}
          <input name="openaiApiKey" type="password" value="{{openaiKeyValue}}" placeholder="sk-..." autocomplete="off" class="cibola8-input" />
        {{/if}}
      </div>
    </div>

    <div class="cibola8-action-bar">
      <button type="button" class="cibola8-tool-btn" data-action="toggleReveal">
        {{#if revealed}}<i class="fas fa-eye-slash"></i>{{else}}<i class="fas fa-eye"></i>{{/if}}
      </button>
      <button type="button" class="cibola8-tool-btn" data-action="copyOpenAIKey" {{#unless revealed}}disabled{{/unless}} data-tooltip="cibola8.token.copy">
        <i class="fas fa-copy"></i>
      </button>
      <button type="button" class="cibola8-btn cibola8-btn--primary" data-action="saveOpenAIKey">
        <i class="fas fa-save"></i> {{localize "cibola8.save"}}
      </button>
    </div>
  </fieldset>
</form>
