<section class="tab standard-form scrollable {{tabs.cibola.cssClass}}" data-tab="cibola"
    data-group="{{tabs.cibola.group}}">

  <fieldset class="boobastudio-glass">
    <legend><i class="fas fa-key"></i> {{localize "boobastudio.settings.apikey"}}</legend>

    <div class="boobastudio-hint boobastudio-mb-2">
      <i class="fas fa-info-circle"></i>
      {{localize "boobastudio.settings.apikeyHint"}}
    </div>

    {{!-- One-click Patreon connect --}}
    <button type="button" class="boobastudio-btn boobastudio-btn--accent boobastudio-btn--full" data-action="connectPatreon">
      <i class="fab fa-patreon"></i> {{localize "boobastudio.connect.button"}}
    </button>
    <p class="boobastudio-hint boobastudio-mt-1 boobastudio-mb-2">
      <i class="fas fa-bolt"></i> {{localize "boobastudio.connect.hint"}}
    </p>

    {{!-- Manual key entry (collapsed) --}}
    <details class="boobastudio-manual-key-section">
      <summary class="boobastudio-btn boobastudio-btn--secondary boobastudio-btn--sm boobastudio-btn--full">
        <i class="fas fa-keyboard"></i> {{localize "boobastudio.connect.manualEntry"}}
      </summary>

      <div class="boobastudio-link-list boobastudio-mb-2 boobastudio-mt-1">
        <a href="{{urls.patreon}}" target="_blank" class="boobastudio-link-item">
          <i class="fab fa-patreon"></i> {{localize "boobastudio.token.getKeyPatreon"}}
        </a>
        <a href="{{urls.app}}" target="_blank" class="boobastudio-link-item">
          <i class="fas fa-globe"></i> {{localize "boobastudio.token.getKeyApp"}}
        </a>
      </div>

      <div class="form-group boobastudio-form-group-animated">
        <label><i class="fas fa-ticket"></i> {{localize "boobastudio.settings.apikey"}}</label>
        <div class="form-fields">
          {{#if revealed}}
            <input name="apikey" type="text" value="{{tokenValue}}" placeholder="{{localize 'boobastudio.settings.apiKeyPlaceholder'}}" class="boobastudio-input" />
          {{else}}
            <input name="apikey" type="password" value="{{tokenValue}}" placeholder="{{localize 'boobastudio.settings.apiKeyPlaceholder'}}" autocomplete="off" class="boobastudio-input" />
          {{/if}}
        </div>
      </div>

      <div class="boobastudio-action-bar">
        <button type="button" class="boobastudio-tool-btn" data-action="toggleReveal" data-tooltip="{{#if revealed}}Hide{{else}}Reveal{{/if}}">
          {{#if revealed}}<i class="fas fa-eye-slash"></i>{{else}}<i class="fas fa-eye"></i>{{/if}}
        </button>
        <button type="button" class="boobastudio-tool-btn" data-action="copyToken" {{#unless revealed}}disabled{{/unless}} data-tooltip="boobastudio.token.copy">
          <i class="fas fa-copy"></i>
        </button>
        <button type="button" class="boobastudio-btn boobastudio-btn--primary" data-action="saveapikey">
          <i class="fas fa-save"></i> {{localize "boobastudio.save"}}
        </button>
      </div>
    </details>

    <hr class="boobastudio-divider" />

    {{!-- Validation --}}
    <p class="boobastudio-hint boobastudio-mb-1">
        <i class="fas fa-lightbulb"></i> {{localize "boobastudio.token.validateHint"}}
    </p>
    <div class="form-group boobastudio-form-group-animated">
      <label><i class="fas fa-check-circle"></i> {{localize "boobastudio.token.validate"}}</label>

      <div class="form-fields boobastudio-validation-row">
        <button type="button" class="boobastudio-btn boobastudio-btn--secondary" data-action="validateToken">
          <i class="fas fa-sync-alt"></i> {{localize "boobastudio.token.validate"}}
        </button>
        <span class="boobastudio-badge boobastudio-badge--lg {{#if (eq status 'valid')}}boobastudio-badge--success{{else if (eq status 'invalid')}}boobastudio-badge--danger{{else}}boobastudio-badge--muted{{/if}}">
          <i class="fas {{#if (eq status 'valid')}}fa-check{{else if (eq status 'invalid')}}fa-times{{else}}fa-question{{/if}}"></i>
          {{statusLabel}}
        </span>
      </div>
    </div>
  </fieldset>

</section>
