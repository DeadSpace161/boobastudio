<section class="tab standard-form scrollable {{tabs.openai.cssClass}}" data-tab="openai"
    data-group="{{tabs.openai.group}}">

  <fieldset class="cibola8-glass cibola8-glass--muted">
    <legend><i class="fas fa-robot"></i> {{localize "cibola8.clientOnly.settings.openaiKey"}}</legend>

    {{!-- Limited-functionality warning --}}
    <div class="cibola8-warning-box cibola8-mb-2">
      <div class="cibola8-warning-icon">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <div class="cibola8-warning-content">
        <p>{{localize "cibola8.clientOnly.settings.limitedWarning"}}</p>
      </div>
    </div>

    <div class="cibola8-hint cibola8-mb-2">
      <i class="fas fa-info-circle"></i>
      {{localize "cibola8.clientOnly.settings.openaiKeyHint"}}
    </div>

    <div class="cibola8-link-list cibola8-mb-2">
      <a href="{{urls.openaiPlatform}}" target="_blank" class="cibola8-link-item">
        <i class="fab fa-openai"></i> {{localize "cibola8.clientOnly.settings.getOpenAIKey"}}
      </a>
    </div>

    <div class="form-group cibola8-form-group-animated">
      <label><i class="fab fa-openai"></i> {{localize "cibola8.clientOnly.settings.openaiKey"}}</label>
      <div class="form-fields">
        {{#if openaiRevealed}}
          <input name="openaiApiKey" type="text" value="{{openaiKeyValue}}" placeholder="sk-..." class="cibola8-input" />
        {{else}}
          <input name="openaiApiKey" type="password" value="{{openaiKeyValue}}" placeholder="sk-..." autocomplete="off" class="cibola8-input" />
        {{/if}}
      </div>
    </div>

    <div class="cibola8-action-bar">
      <button type="button" class="cibola8-tool-btn" data-action="toggleOpenAIReveal" data-tooltip="{{#if openaiRevealed}}Hide{{else}}Reveal{{/if}}">
        {{#if openaiRevealed}}<i class="fas fa-eye-slash"></i>{{else}}<i class="fas fa-eye"></i>{{/if}}
      </button>
      <button type="button" class="cibola8-tool-btn" data-action="copyOpenAIKey" {{#unless openaiRevealed}}disabled{{/unless}} data-tooltip="cibola8.token.copy">
        <i class="fas fa-copy"></i>
      </button>
      <button type="button" class="cibola8-btn cibola8-btn--primary" data-action="saveOpenAIKey">
        <i class="fas fa-save"></i> {{localize "cibola8.save"}}
      </button>
    </div>
  </fieldset>

</section>
