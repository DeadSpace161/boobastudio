<section class="tab standard-form scrollable {{tabs.openai.cssClass}}" data-tab="openai"
    data-group="{{tabs.openai.group}}">

  <fieldset class="boobastudio-glass boobastudio-glass--muted">
    <legend><i class="fas fa-robot"></i> {{localize "boobastudio.clientOnly.settings.openaiKey"}}</legend>

    {{!-- Limited-functionality warning --}}
    <div class="boobastudio-warning-box boobastudio-mb-2">
      <div class="boobastudio-warning-icon">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <div class="boobastudio-warning-content">
        <p>{{localize "boobastudio.clientOnly.settings.limitedWarning"}}</p>
      </div>
    </div>

    <div class="boobastudio-hint boobastudio-mb-2">
      <i class="fas fa-info-circle"></i>
      {{localize "boobastudio.clientOnly.settings.openaiKeyHint"}}
    </div>

    <div class="boobastudio-link-list boobastudio-mb-2">
      <a href="{{urls.openaiPlatform}}" target="_blank" class="boobastudio-link-item">
        <i class="fab fa-openai"></i> {{localize "boobastudio.clientOnly.settings.getOpenAIKey"}}
      </a>
    </div>

    <div class="form-group boobastudio-form-group-animated">
      <label><i class="fab fa-openai"></i> {{localize "boobastudio.clientOnly.settings.openaiKey"}}</label>
      <div class="form-fields">
        {{#if openaiRevealed}}
          <input name="openaiApiKey" type="text" value="{{openaiKeyValue}}" placeholder="sk-..." class="boobastudio-input" />
        {{else}}
          <input name="openaiApiKey" type="password" value="{{openaiKeyValue}}" placeholder="sk-..." autocomplete="off" class="boobastudio-input" />
        {{/if}}
      </div>
    </div>

    <div class="boobastudio-action-bar">
      <button type="button" class="boobastudio-tool-btn" data-action="toggleOpenAIReveal" data-tooltip="{{#if openaiRevealed}}Hide{{else}}Reveal{{/if}}">
        {{#if openaiRevealed}}<i class="fas fa-eye-slash"></i>{{else}}<i class="fas fa-eye"></i>{{/if}}
      </button>
      <button type="button" class="boobastudio-tool-btn" data-action="copyOpenAIKey" {{#unless openaiRevealed}}disabled{{/unless}} data-tooltip="boobastudio.token.copy">
        <i class="fas fa-copy"></i>
      </button>
      <button type="button" class="boobastudio-btn boobastudio-btn--primary" data-action="saveOpenAIKey">
        <i class="fas fa-save"></i> {{localize "boobastudio.save"}}
      </button>
    </div>
  </fieldset>

</section>
