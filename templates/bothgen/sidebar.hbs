{{!-- History/Gallery Sidebar Partial --}}
<fieldset class="flexcol stretch wrapping hideOnCrop max100height boobastudio-glass boobastudio-history-sidebar">
    <legend class="boobastudio-sidebar-tabs">
        <button type="button"
                data-action="showSidebarTab"
                data-tab="history"
                class="boobastudio-sidebar-tab active">
            <i class="fas fa-clock-rotate-left"></i>
            <span>{{localize 'boobastudio.history'}}</span>
        </button>
        <button type="button"
                data-action="showSidebarTab"
                data-tab="gallery"
                class="boobastudio-sidebar-tab">
            <i class="fas fa-images"></i>
            <span>{{localize 'boobastudio.AiBrowser.title'}}</span>
        </button>
    </legend>
    {{!-- History content --}}
    <div class="boobastudio-sidebar-content boobastudio-sidebar-history max100height scrollable" data-sidebar-tab="history">
        <div class="imageHistory max100height">
            <div class="boobastudio-history-grid max100height"></div>
        </div>
    </div>
    {{!-- Gallery content --}}
    <div class="boobastudio-sidebar-content boobastudio-sidebar-gallery max100height scrollable hidden" data-sidebar-tab="gallery">
        {{!-- Gallery will be injected here by GalleryComponent --}}
    </div>
</fieldset>
