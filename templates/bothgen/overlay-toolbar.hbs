{{!-- Overlay Toolbar Partial (zoom, brush, selection controls) --}}
<div class="boobastudio-toolbar-container boobastudio-toolbar-container--overlay hideOnCrop imageControlContainer">
    {{!-- Main row: existing controls --}}
    <div class="flexrow boobastudio-toolbar boobastudio-toolbar--overlay">
        <button type="button" data-tooltip="boobastudio.showArtwork" data-action="showArtwork"
            class="imgControls {{ifThen image.latestImg '' 'hidden'}} boobastudio-tool-btn"><i
                class="fas fa-maximize"></i></button>
        <button type="button" data-tooltip="boobastudio.postChat" data-action="postChat"
            class="imgControls hidden boobastudio-tool-btn"><i class="fas fa-comment"></i></button>
        {{!-- Zoom controls --}}
        <span class="boobastudio-zoom-controls">
            <button type="button" data-action="zoomOut" data-tooltip="boobastudio.canvas.zoomOut"
                class="boobastudio-tool-btn"><i class="fas fa-minus"></i></button>
            <span class="boobastudio-zoom-value">100%</span>
            <button type="button" data-action="zoomIn" data-tooltip="boobastudio.canvas.zoomIn"
                class="boobastudio-tool-btn"><i class="fas fa-plus"></i></button>
            <button type="button" data-action="fitToView" data-tooltip="boobastudio.canvas.fitToView"
                class="boobastudio-tool-btn"><i class="fas fa-expand"></i></button>
        </span>
    </div>

    {{!-- Second row: Brush size (shown when brush tool active) --}}
    <div class="flexrow boobastudio-toolbar boobastudio-toolbar--overlay boobastudio-brush-context hidden">
        <label class="boobastudio-context-label">
            <i class="fas fa-paintbrush"></i>
            <span>{{localize 'boobastudio.canvas.brushSize'}}</span>
        </label>
        <input type="range" class="boobastudio-brush-size-slider" min="1" max="200" value="20" />
        <span class="boobastudio-brush-size-value">20px</span>
    </div>

    {{!-- Third row: Selection actions (shown when selection tool active) --}}
    <div class="flexrow boobastudio-toolbar boobastudio-toolbar--overlay boobastudio-selection-actions hidden">
        <button type="button" data-action="clearSelection" data-tooltip="boobastudio.canvas.clearSelection"
            class="boobastudio-tool-btn">
            <i class="fas fa-times"></i>
        </button>
        <button type="button" data-action="invertSelection" data-tooltip="boobastudio.canvas.invertSelection"
            class="boobastudio-tool-btn">
            <i class="fas fa-arrows-rotate"></i>
        </button>
        <button type="button" data-action="selectAll" data-tooltip="boobastudio.canvas.selectAll"
            class="boobastudio-tool-btn">
            <i class="fas fa-border-all"></i>
        </button>
    </div>

    {{!-- Fourth row: Crop context (shown when crop tool active) --}}
    <div class="flexrow boobastudio-toolbar boobastudio-toolbar--overlay boobastudio-crop-context hidden">
        <button type="button" data-tooltip="boobastudio.toolbar.cropHint" class="boobastudio-tool-btn" disabled>
            <i class="fas fa-crop"></i>
        </button>
        <div class="boobastudio-toolbar__separator"></div>
        <button type="button" data-action="setCropRatio" data-ratio="16:9"
            data-tooltip="boobastudio.toolbar.ratio16x9"
            class="boobastudio-tool-btn">
            <i class="fas fa-rectangle-wide"></i>
            <span>16:9</span>
        </button>
        <button type="button" data-action="setCropRatio" data-ratio="4:3"
            data-tooltip="boobastudio.toolbar.ratio4x3"
            class="boobastudio-tool-btn">
            <i class="fas fa-rectangle-landscape"></i>
            <span>4:3</span>
        </button>
        <button type="button" data-action="setCropRatio" data-ratio="1:1"
            data-tooltip="boobastudio.toolbar.ratio1x1"
            class="boobastudio-tool-btn">
            <i class="fas fa-square"></i>
            <span>1:1</span>
        </button>
        <button type="button" data-action="setCropRatio" data-ratio="free"
            data-tooltip="boobastudio.toolbar.ratioFree"
            class="boobastudio-tool-btn boobastudio-tool-btn--active">
            <i class="fas fa-expand"></i>
            <span>{{localize 'boobastudio.free'}}</span>
        </button>
        <div class="boobastudio-toolbar__separator"></div>
        <button type="button" data-action="cropConfirm"
            data-tooltip="boobastudio.toolbar.cropConfirm"
            class="boobastudio-tool-btn boobastudio-tool-btn--success">
            <i class="fas fa-check"></i>
        </button>
        <button type="button" data-action="cropCancel"
            data-tooltip="boobastudio.toolbar.cropCancel"
            class="boobastudio-tool-btn boobastudio-tool-btn--danger">
            <i class="fas fa-times"></i>
        </button>
    </div>
</div>
