<section class="tab standard-form scrollable {{tabs.config.cssClass}}" data-tab="config"
    data-group="{{tabs.config.group}}">
    {{#if image.canImage}}
    {{> modules/boobastudio/templates/modelselector.hbs fieldname="image.model"}}
    <fieldset class="stretch t-spacer">
        <legend><i class="fas fa-cogs"></i> {{localize 'boobastudio.parameterConfig'}}</legend>
        <div class="flexcol">
            <div class="flexrow imagesGroupLabel">
                <label class="centerText" data-tooltip="boobastudio.behaviorHint">
                    {{localize 'boobastudio.behavior'}} <span class="fa-stack" style="font-size:0.5em;">
                        <i class="fa-regular fa-circle fa-stack-2x"></i>
                        <i class="fa-solid fa-info fa-stack-1x"></i>
                    </span>
                </label>
                <label class="centerText" data-tooltip="boobastudio.drawingStyleHint" style="margin:0 auto">
                    {{localize 'boobastudio.drawingStyle'}} <span class="fa-stack" style="font-size:0.5em;">
                        <i class="fa-regular fa-circle fa-stack-2x"></i>
                        <i class="fa-solid fa-info fa-stack-1x"></i>
                    </span>
                </label>
            </div>
            <div class="flexrow">
                <div class="imagesGroupParent">
                    <div class="radioImagesGroup flexrow wrapping hideChoices">
                        {{#each image.behaviors as |item key|}}
                        <input type="radio" id="behavior_{{key}}_{{../randomId}}" name="image.behavior" value="{{key}}" {{#if (eq key
                            ../image.behavior)}}checked{{/if}}>
                        <label for="behavior_{{key}}_{{../randomId}}">
                            <img src="modules/boobastudio/templates/assets/{{key}}.webp" alt="{{key}}">
                            <div class="img-overlay">{{localize (cibolaConcat 'boobastudio.behaviors.' key)}}</div>
                            <i class="fas fa-edit"></i>
                        </label>
                        {{/each}}
                    </div>
                </div>
                <div class="imagesGroupParent">
                    <div class="radioImagesGroup flexrow wrapping hideChoices">
                        {{#each image.drawingStyles as |item key|}}
                        <input type="radio" id="drawingstyle_{{key}}_{{../randomId}}" name="image.drawingStyle" value="{{key}}" {{#if
                            (eq key ../image.drawingStyle)}}checked{{/if}}>
                        <label for="drawingstyle_{{key}}_{{../randomId}}">
                            <img src="modules/boobastudio/templates/assets/{{key}}.webp" alt="{{key}}">
                            <div class="img-overlay">{{localize (cibolaConcat 'boobastudio.drawingStyles.' key)}}</div>
                            <i class="fas fa-edit"></i>
                        </label>
                        {{/each}}
                    </div>
                </div>
            </div>
        </div>
    </fieldset>

    <fieldset class="stretch t-spacer">
        <legend>{{localize 'boobastudio.advancedConfig'}}</legend>
        <div class="form-group">
            <label>{{localize 'boobastudio.drawingType'}}</label>
            <div class="form-fields">
                <select class="drawingType" name="image.{{item.documentName}}.{{item.type}}.drawingType">
                    {{selectOptions image.drawingTypes selected=image.drawingType localize=true}}
                </select>
            </div>
            <p class="hint">{{localize 'boobastudio.drawingTypeHint'}}</p>
        </div>

        <div class="form-group {{#unless image.properties}}hidden{{/unless}}">
            <label>{{localize 'boobastudio.AiImageGen.property'}}</label>
            <div class="form-fields">
                <select name="defaultProperty">
                    {{selectOptions image.properties selected=image.selectedProperty valueAttr="value" labelAttr="label"
                    blank=""}}
                </select>
            </div>
            <p class="hint">{{localize 'boobastudio.defineProperties'}}</p>
        </div>

    </fieldset>
    {{/if}}
</section>