<section class="journal-page-content stretch flexcol scrollable boobastudio-thread">
    <div class="boobastudio-thread__messages mainContentScroller {{ifThen isV1 '' 'scrollable'}} stretch">
        {{#unless document.system.messages}}
        <div class="boobastudio-thread__welcome">
            <div class="boobastudio-intro-text boobastudio-mb-3">
                <i class="fas fa-comments boobastudio-intro-icon"></i>
                <span>{{localize 'boobastudio.AiThread.explanation'}}</span>
            </div>
            <div class="boobastudio-card-grid boobastudio-card-grid--2">
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.1'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.2'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.3'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.4'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.5'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.6'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.7'}}}</div>
                <div class="boobastudio-card boobastudio-card--compact">{{{localize 'boobastudio.AiThread.example.8'}}}</div>
            </div>
        </div>
        {{/unless}}
        {{#each document.system.messages as |message|}}
        {{> modules/boobastudio/templates/thread/message.hbs message=message isWritable=../isWritable}}
        {{/each}}
    </div>
    <div class="hidden jump-to-bottom boobastudio-thread__jump-bottom">
        <a aria-label="{{localize 'CHAT.JumpToBottom'}}" role="button"><i class="fas fa-keyboard-down"></i>
            {{localize "CHAT.JumpToBottom"}}</a>
    </div>
    {{#if userInfo.alive}}
    <div class="boobastudio-thread__input inputcontainer">
        <div class="boobastudio-thread__health" data-tooltip="boobastudio.health">
            <div class="progressbar aihealth" style="--height: {{userInfo.health}}" data-label="{{userPercent}}"></div>
        </div>
        <button type="button" class="boobastudio-btn boobastudio-btn--icon boobastudio-btn--ghost ellipsisMenu" data-tooltip="boobastudio.options">
            <i class="fas fa-ellipsis-vertical"></i>
        </button>
        <textarea class="boobastudio-textarea boobastudio-thread__textarea" {{#unless isWritable}}disabled{{/unless}}
            name="prompt" placeholder="{{localize 'boobastudio.AiThread.sendMessage'}}"></textarea>
        <button type="button" class="boobastudio-btn boobastudio-btn--primary" data-action="sendMessage" {{#unless isWritable}}disabled{{/unless}}>
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
    {{else}}
    {{{patreon}}}
    {{/if}}
</section>