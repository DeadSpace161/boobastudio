<div class="cibola8-thread-settings">
    <fieldset class="cibola8-glass">
        <legend><i class="fas fa-cog"></i> {{localize "cibola8.AiThread.title"}}</legend>

        <div class="flexrow cibola8 app">
            <div class="imagesGroupParent">
                {{> modules/cibola8/templates/innermodelselector.hbs models=models fieldname='system.model'
                selectedModel=document.system.model}}
            </div>
        </div>

        {{formGroup systemFields.max_messages value=document.system.max_messages name='system.max_messages' }}
        {{formGroup systemFields.enable_assistant value=document.system.enable_assistant name='system.enable_assistant' }}
        <div class="max_history_container modelIsNotAdvanced {{ifThen modelData.advanced 'hidden' ''}}">
            {{formGroup systemFields.max_history value=document.system.max_history name='system.max_history' }}
        </div>
    </fieldset>
    <fieldset class="cibola8-glass">
        <legend><i class="fas fa-cloud-upload-alt"></i> {{localize "cibola8.vector.uploadTitle"}}</legend>
        <div class="modelIsAdvanced {{ifThen modelData.advanced '' 'hidden'}}">
            {{#if (gt userInfo.level 0)}}
            <div class="cibola8-hint cibola8-mb-2">{{{localize 'cibola8.vector.uploadFile'}}}</div>
            {{else}}
            <div class="cibola8-hint cibola8-hint--warning cibola8-mb-2">{{localize 'cibola8.vector.notAvailable'}}</div>
            {{/if}}

            {{#if userInfo.alive}}
            <div class="cibola8-thread-settings__cost">
                <span><b>{{localize 'cibola8.vector.estimatedCost'}}</b>:</span>
                <span class="estimatedcost"><i class="fas fa-spinner fa-spin"></i></span>
                <i class="fas fa-times"></i>
                <span class="manapot"></span>
            </div>

            {{> modules/cibola8/templates/vector/showstorage.hbs}}
            {{else}}
            {{{patreon}}}
            {{/if}}
        </div>
        <div class="modelIsNotAdvanced {{ifThen modelData.advanced 'hidden' ''}}">
            <div class="cibola8-hint">{{localize 'cibola8.vector.notForThisModel'}}</div>
        </div>
    </fieldset>
</div>