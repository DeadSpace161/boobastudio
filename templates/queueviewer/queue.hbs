<section class="boobastudio-queue-viewer scrollable">
  {{!-- Header Section --}}
  <div class="boobastudio-page-header">
    <div class="boobastudio-page-header__content">
      <div class="boobastudio-page-header__icon">
        <i class="fas fa-list-check"></i>
      </div>
      <div class="boobastudio-page-header__text">
        <h3>{{localize 'boobastudio.QueueViewer.title'}}</h3>
        <p>{{localize 'boobastudio.QueueViewer.description'}}</p>
      </div>
    </div>
    <div class="boobastudio-page-header__actions">
      <button type="button" class="boobastudio-btn boobastudio-btn--secondary boobastudio-btn--sm" data-action="cleanAll" data-tooltip="{{localize 'boobastudio.QueueViewer.cleanAll'}}">
        <i class="fas fa-broom"></i>
        <span>{{localize 'boobastudio.QueueViewer.cleanAll'}}</span>
      </button>
    </div>
  </div>

  {{!-- Queue Items --}}
  <div class="boobastudio-queue-list">
    {{#if queue.length}}
      {{#each queue as |element|}}
        <div class="boobastudio-queue-item {{#if element.finished}}{{#if element.success}}boobastudio-queue-item--success{{else}}boobastudio-queue-item--danger{{/if}}{{else}}boobastudio-queue-item--pending{{/if}}" data-id="{{element.id}}">

          {{!-- Item Header --}}
          <div class="boobastudio-queue-item__header">
            <div class="boobastudio-queue-item__icon">
              {{#if element.isPack}}
                <i class="fas fa-atlas" data-tooltip="{{localize 'boobastudio.QueueViewer.compendium'}}"></i>
              {{else}}
                {{#if element.document.img}}
                  <img src="{{element.document.img}}" alt="" class="boobastudio-portrait boobastudio-portrait--md"/>
                {{else}}
                  <i class="fas fa-file-alt"></i>
                {{/if}}
              {{/if}}
            </div>

            <div class="boobastudio-queue-item__info">
              <div class="boobastudio-queue-item__name">
                {{#if element.isPack}}
                  <a class="openElement boobastudio-link" data-uuid="{{element.document.metadata.id}}" data-ispack="true">
                    {{element.document.metadata.label}}
                  </a>
                  <small class="text-muted">{{element.document.metadata.id}}</small>
                {{else}}
                  <a class="openElement boobastudio-link" data-uuid="{{element.document.uuid}}">
                    {{element.document.name}}
                  </a>
                {{/if}}
              </div>
            </div>

            <div class="boobastudio-queue-item__status">
              {{#if element.finished}}
                {{#if element.success}}
                  <span class="boobastudio-badge boobastudio-badge--success" data-tooltip="{{localize 'boobastudio.QueueViewer.success'}}">
                    <i class="fas fa-check"></i> {{localize 'boobastudio.QueueViewer.success'}}
                  </span>
                {{else}}
                  <span class="boobastudio-badge boobastudio-badge--danger" data-tooltip="{{localize 'boobastudio.QueueViewer.failed'}}">
                    <i class="fas fa-exclamation-triangle"></i> {{localize 'boobastudio.QueueViewer.failed'}}
                  </span>
                {{/if}}
              {{else}}
                <span class="boobastudio-badge boobastudio-badge--warning">
                  <i class="fas fa-spinner fa-spin"></i> {{localize 'boobastudio.QueueViewer.processing'}}
                </span>
              {{/if}}
            </div>
          </div>

          {{!-- Progress Bar --}}
          <div class="boobastudio-queue-item__progress boobastudio-progress">
            <div class="boobastudio-progress__bar">
              <div class="boobastudio-progress__fill" style="width: {{element.progress}}%"></div>
            </div>
            <span class="boobastudio-progress__text">{{element.progress}}%</span>
          </div>

          {{!-- Item Details --}}
          <div class="boobastudio-queue-item__details">
            <div class="boobastudio-detail">
              <i class="fas fa-hourglass-start"></i>
              <span data-tooltip="{{localize 'boobastudio.QueueViewer.start'}}">{{timeSince element.started}}</span>
            </div>

            {{#if element.finished}}
              <div class="boobastudio-detail">
                <i class="fas fa-hourglass-end"></i>
                <span data-tooltip="{{localize 'boobastudio.QueueViewer.end'}}">{{timeSince element.finished}}</span>
              </div>
            {{/if}}

            {{#if element.status.total}}
              <div class="boobastudio-detail boobastudio-queue-breakdown">
                <i class="fas fa-chart-pie" data-tooltip="{{localize 'boobastudio.QueueViewer.elementStatus'}}"></i>
                <span class="boobastudio-stats">
                  <span class="boobastudio-stats__item" data-tooltip="{{localize 'boobastudio.QueueViewer.enqueued'}}">{{element.status.enqueued}}</span>
                  <span class="boobastudio-stats__sep">/</span>
                  <span class="boobastudio-stats__item boobastudio-stats__item--success" data-tooltip="{{localize 'boobastudio.QueueViewer.success'}}">{{element.status.success}}</span>
                  <span class="boobastudio-stats__sep">/</span>
                  <span class="boobastudio-stats__item boobastudio-stats__item--danger" data-tooltip="{{localize 'boobastudio.QueueViewer.failed'}}">{{element.status.error}}</span>
                  <span class="boobastudio-stats__sep">/</span>
                  <span class="boobastudio-stats__item" data-tooltip="{{localize 'boobastudio.QueueViewer.total'}}">{{element.status.total}}</span>
                </span>
              </div>
            {{/if}}

            {{!-- Delete Button --}}
            {{#if element.finished}}
              <button type="button" class="boobastudio-btn boobastudio-btn--icon boobastudio-btn--danger" data-action="abortElement" data-id="{{element.id}}" data-tooltip="{{localize 'boobastudio.delete'}}">
                <i class="fas fa-trash"></i>
              </button>
            {{/if}}
          </div>
        </div>
      {{/each}}
    {{else}}
      {{!-- Empty State --}}
      <div class="boobastudio-empty-state">
        <div class="boobastudio-empty-icon">
          <i class="fas fa-inbox"></i>
        </div>
        <h4>{{localize 'boobastudio.QueueViewer.empty'}}</h4>
        <p class="text-muted">{{localize 'boobastudio.QueueViewer.emptyHint'}}</p>
      </div>
    {{/if}}
  </div>
</section>