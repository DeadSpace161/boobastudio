<div class="cibola8-dialog-content">
  {{!-- Header --}}
  <header class="cibola8-dialog-header">
    <div class="cibola8-dialog-header-icon cibola8-dialog-header-icon--feedback">
      <i class="fas fa-comment-dots"></i>
    </div>
    <div class="cibola8-dialog-header-content">
      <p>{{localize 'cibola8.grudge.description'}}</p>
    </div>
  </header>

  {{!-- Contact Options --}}
  <div class="cibola8-contact-section">
    <h4 class="cibola8-section-title">
      <i class="fas fa-headset"></i>
      {{localize 'cibola8.grudge.getInContact'}}
    </h4>
    
    <div class="cibola8-contact-grid">
      <a href="https://discord.gg/TYbUBfzzqN" target="_blank" class="cibola8-contact-card cibola8-contact-card--discord">
        <div class="cibola8-contact-card-icon">
          <i class="fab fa-discord"></i>
        </div>
        <div class="cibola8-contact-card-content">
          <span class="cibola8-contact-card-title">Discord</span>
          <span class="cibola8-contact-card-desc">{{localize 'cibola8.grudge.discord'}}</span>
        </div>
        <i class="fas fa-external-link-alt cibola8-contact-card-arrow"></i>
      </a>

      <a href="https://github.com/Cibola8/cibola8" target="_blank" class="cibola8-contact-card cibola8-contact-card--github">
        <div class="cibola8-contact-card-icon">
          <i class="fab fa-github"></i>
        </div>
        <div class="cibola8-contact-card-content">
          <span class="cibola8-contact-card-title">GitHub</span>
          <span class="cibola8-contact-card-desc">{{localize 'cibola8.grudge.github'}}</span>
        </div>
        <i class="fas fa-external-link-alt cibola8-contact-card-arrow"></i>
      </a>

      <a href="https://www.patreon.com/Cibola" target="_blank" class="cibola8-contact-card cibola8-contact-card--patreon">
        <div class="cibola8-contact-card-icon">
          <i class="fab fa-patreon"></i>
        </div>
        <div class="cibola8-contact-card-content">
          <span class="cibola8-contact-card-title">Patreon</span>
          <span class="cibola8-contact-card-desc">{{localize 'cibola8.grudge.patreon'}}</span>
        </div>
        <i class="fas fa-external-link-alt cibola8-contact-card-arrow"></i>
      </a>

      <a href="https://www.youtube.com/@Cibola8" target="_blank" class="cibola8-contact-card cibola8-contact-card--youtube">
        <div class="cibola8-contact-card-icon">
          <i class="fab fa-youtube"></i>
        </div>
        <div class="cibola8-contact-card-content">
          <span class="cibola8-contact-card-title">YouTube</span>
          <span class="cibola8-contact-card-desc">{{localize 'cibola8.grudge.youtube'}}</span>
        </div>
        <i class="fas fa-external-link-alt cibola8-contact-card-arrow"></i>
      </a>
    </div>
  </div>

  {{!-- Changelog Link --}}
  <div class="cibola8-changelog-link">
    <p>{{{localize 'cibola8.changelog'}}}</p>
  </div>
</div>