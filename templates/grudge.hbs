<div class="boobastudio-dialog-content">
  {{!-- Header --}}
  <header class="boobastudio-dialog-header">
    <div class="boobastudio-dialog-header-icon boobastudio-dialog-header-icon--feedback">
      <i class="fas fa-comment-dots"></i>
    </div>
    <div class="boobastudio-dialog-header-content">
      <p>{{localize 'boobastudio.grudge.description'}}</p>
    </div>
  </header>

  {{!-- Contact Options --}}
  <div class="boobastudio-contact-section">
    <h4 class="boobastudio-section-title">
      <i class="fas fa-headset"></i>
      {{localize 'boobastudio.grudge.getInContact'}}
    </h4>

    <div class="boobastudio-contact-grid">
      <a href="https://discord.gg/TYbUBfzzqN" target="_blank" class="boobastudio-contact-card boobastudio-contact-card--discord">
        <div class="boobastudio-contact-card-icon">
          <i class="fab fa-discord"></i>
        </div>
        <div class="boobastudio-contact-card-content">
          <span class="boobastudio-contact-card-title">Discord</span>
          <span class="boobastudio-contact-card-desc">{{localize 'boobastudio.grudge.discord'}}</span>
        </div>
        <i class="fas fa-external-link-alt boobastudio-contact-card-arrow"></i>
      </a>

      <a href="https://github.com/BoobaStudio/boobastudio" target="_blank" class="boobastudio-contact-card boobastudio-contact-card--github">
        <div class="boobastudio-contact-card-icon">
          <i class="fab fa-github"></i>
        </div>
        <div class="boobastudio-contact-card-content">
          <span class="boobastudio-contact-card-title">GitHub</span>
          <span class="boobastudio-contact-card-desc">{{localize 'boobastudio.grudge.github'}}</span>
        </div>
        <i class="fas fa-external-link-alt boobastudio-contact-card-arrow"></i>
      </a>

      <a href="https://github.com/DeadSpace161/boobastudio/issues" target="_blank" class="boobastudio-contact-card boobastudio-contact-card--patreon">
        <div class="boobastudio-contact-card-icon">
          <i class="fas fa-life-ring"></i>
        </div>
        <div class="boobastudio-contact-card-content">
          <span class="boobastudio-contact-card-title">Issues</span>
          <span class="boobastudio-contact-card-desc">{{localize 'boobastudio.grudge.patreon'}}</span>
        </div>
        <i class="fas fa-external-link-alt boobastudio-contact-card-arrow"></i>
      </a>

      <a href="https://www.youtube.com/@BoobaStudio" target="_blank" class="boobastudio-contact-card boobastudio-contact-card--youtube">
        <div class="boobastudio-contact-card-icon">
          <i class="fab fa-youtube"></i>
        </div>
        <div class="boobastudio-contact-card-content">
          <span class="boobastudio-contact-card-title">YouTube</span>
          <span class="boobastudio-contact-card-desc">{{localize 'boobastudio.grudge.youtube'}}</span>
        </div>
        <i class="fas fa-external-link-alt boobastudio-contact-card-arrow"></i>
      </a>
    </div>
  </div>

  {{!-- Changelog Link --}}
  <div class="boobastudio-changelog-link">
    <p>{{{localize 'boobastudio.changelog'}}}</p>
  </div>
</div>
