<section class="tab standard-form {{tabs.generator.cssClass}}" data-tab="generator"
    data-group="{{tabs.generator.group}}" style="display: flex; flex-direction: column;">

    {{#if userInfo.alive}}
    <div class="flexrow boobastudio-settings-row boobastudio-mb-2" style="gap: 0.75rem;">
        <div class="form-group boobastudio-form-group-animated" data-tooltip="boobastudio.temperatureHint" style="flex: 1;">
            <label><i class="fas fa-temperature-half"></i> {{localize 'boobastudio.fields.creativity'}}</label>
            <div class="form-fields">
                <range-picker name="temperature" value="0.7" min="0" max="1" step="0.1"></range-picker>
            </div>
        </div>
        <div class="form-group boobastudio-form-group-animated" style="flex: 1;">
            <label><i class="fas fa-text-width"></i> {{localize 'boobastudio.textlength'}}</label>
            <div class="form-fields">
                <select name="wordcount" class="boobastudio-select-enhanced">
                    {{selectOptions random.words selected=50 localize=true}}
                </select>
            </div>
        </div>
    </div>

    <div class="boobastudio-chat-history" style="flex: 1; overflow-y: auto; padding: 0.5rem; display: flex; flex-direction: column; gap: 0.75rem; min-height: 150px;">
        <div class="boobastudio-intro-text boobastudio-chat-empty">
            <i class="fas fa-dice boobastudio-intro-icon"></i>
            <span>{{localize 'boobastudio.AiRandomGen.description'}}</span>
        </div>
    </div>

    <div style="flex-shrink: 0; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08);">
        <textarea class="prompt boobastudio-textarea" rows="3" placeholder="{{localize 'boobastudio.iterativeGen.promptPlaceholder'}}" style="width: 100%; resize: vertical;">{{random.prompt}}</textarea>
        <div class="flexrow" style="gap: 0.5rem; margin-top: 0.5rem;">
            <button type="button" class="boobastudio-btn boobastudio-btn--primary" data-tooltip="boobastudio.spinner" data-action="generate" style="flex: 1;">
                <i class="fas fa-wand-magic-sparkles"></i> {{localize 'boobastudio.iterativeGen.generate'}}
            </button>
        </div>
    </div>
    {{else}}
        {{{patreon}}}
    {{/if}}

</section>