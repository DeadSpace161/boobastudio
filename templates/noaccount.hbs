
<div class="boobastudio-noaccount-container">
  {{!-- Warning Banner --}}
  <div class="boobastudio-warning-box">
    <div class="boobastudio-warning-icon">
      <i class="fas fa-exclamation-triangle"></i>
    </div>
    <div class="boobastudio-warning-content">
      <h3>{{localize 'boobastudio.error.noConnection'}}</h3>
      <p>{{localize 'boobastudio.error.noConnectionDesc'}}</p>
    </div>
  </div>

  {{!-- Options Section --}}
  <div class="boobastudio-options-section">
    {{!-- Get API Key Links --}}
    <div class="boobastudio-link-list boobastudio-mb-2">
      <a href="{{urls.patreon}}" target="_blank" class="boobastudio-link-item">
        <i class="fab fa-patreon"></i> {{localize "boobastudio.token.getKeyPatreon"}}
      </a>
      <a href="{{urls.app}}" target="_blank" class="boobastudio-link-item">
        <i class="fas fa-globe"></i> {{localize "boobastudio.token.getKeyApp"}}
      </a>
    </div>

    <hr class="boobastudio-divider" />

    {{!-- Primary Action: Connect with Patreon --}}
    <div class="boobastudio-action-card">
      <div class="boobastudio-action-card-icon">
        <i class="fab fa-patreon"></i>
      </div>
      <div class="boobastudio-action-card-content">
        <h4>{{localize 'boobastudio.connect.button'}}</h4>
        <p>{{localize 'boobastudio.connect.hint'}}</p>
      </div>
      <button class="boobastudio-btn--primary boobastudio-btn--accent" data-action="connectPatreon" type="button">
        <i class="fab fa-patreon"></i> {{localize 'boobastudio.connect.button'}}
      </button>
    </div>

    <hr class="boobastudio-divider" />

    {{!-- Alternative: Manual Key Entry --}}
    <div class="boobastudio-action-card">
      <div class="boobastudio-action-card-icon">
        <i class="fas fa-key"></i>
      </div>
      <div class="boobastudio-action-card-content">
        <h4>{{localize 'boobastudio.token.configureAccess'}}</h4>
        <p>{{localize 'boobastudio.token.configureAccessDesc'}}</p>
      </div>
      <button class="boobastudio-btn--primary" data-action="openTokenSettings" type="button">
        <i class="fas fa-keyboard"></i> {{localize 'boobastudio.connect.manualEntry'}}
      </button>
    </div>

    {{!-- Alternative: Client-Only Mode --}}
    <div class="boobastudio-action-card boobastudio-action-card-secondary">
      <div class="boobastudio-action-card-icon">
        <i class="fab fa-openai"></i>
      </div>
      <div class="boobastudio-action-card-content">
        <h4>{{localize 'boobastudio.clientOnly.title'}}</h4>
        <p>{{localize 'boobastudio.clientOnly.description'}}</p>
      </div>
    </div>
  </div>
</div>