
<div class="cibola8-noaccount-container">
  {{!-- Warning Banner --}}
  <div class="cibola8-warning-box">
    <div class="cibola8-warning-icon">
      <i class="fas fa-exclamation-triangle"></i>
    </div>
    <div class="cibola8-warning-content">
      <h3>{{localize 'cibola8.error.noConnection'}}</h3>
      <p>{{localize 'cibola8.error.noConnectionDesc'}}</p>
    </div>
  </div>

  {{!-- Options Section --}}
  <div class="cibola8-options-section">
    {{!-- Get API Key Links --}}
    <div class="cibola8-link-list cibola8-mb-2">
      <a href="{{urls.patreon}}" target="_blank" class="cibola8-link-item">
        <i class="fab fa-patreon"></i> {{localize "cibola8.token.getKeyPatreon"}}
      </a>
      <a href="{{urls.app}}" target="_blank" class="cibola8-link-item">
        <i class="fas fa-globe"></i> {{localize "cibola8.token.getKeyApp"}}
      </a>
    </div>

    <hr class="cibola8-divider" />
    
    {{!-- Primary Action: Connect with Patreon --}}
    <div class="cibola8-action-card">
      <div class="cibola8-action-card-icon">
        <i class="fab fa-patreon"></i>
      </div>
      <div class="cibola8-action-card-content">
        <h4>{{localize 'cibola8.connect.button'}}</h4>
        <p>{{localize 'cibola8.connect.hint'}}</p>
      </div>
      <button class="cibola8-btn--primary cibola8-btn--accent" data-action="connectPatreon" type="button">
        <i class="fab fa-patreon"></i> {{localize 'cibola8.connect.button'}}
      </button>
    </div>

    <hr class="cibola8-divider" />

    {{!-- Alternative: Manual Key Entry --}}
    <div class="cibola8-action-card">
      <div class="cibola8-action-card-icon">
        <i class="fas fa-key"></i>
      </div>
      <div class="cibola8-action-card-content">
        <h4>{{localize 'cibola8.token.configureAccess'}}</h4>
        <p>{{localize 'cibola8.token.configureAccessDesc'}}</p>
      </div>
      <button class="cibola8-btn--primary" data-action="openTokenSettings" type="button">
        <i class="fas fa-keyboard"></i> {{localize 'cibola8.connect.manualEntry'}}
      </button>
    </div>

    {{!-- Alternative: Client-Only Mode --}}
    <div class="cibola8-action-card cibola8-action-card-secondary">
      <div class="cibola8-action-card-icon">
        <i class="fab fa-openai"></i>
      </div>
      <div class="cibola8-action-card-content">
        <h4>{{localize 'cibola8.clientOnly.title'}}</h4>
        <p>{{localize 'cibola8.clientOnly.description'}}</p>
      </div>
    </div>
  </div>
</div>