<div class="radioImagesGroupBig flexrow modellist">
    {{#each models as |item key|}}
    <input type="radio" id="model_{{key}}_{{../randomId}}" name="{{../fieldname}}" value="{{key}}" {{#if (eq key ../selectedModel)}}checked{{/if}} {{#if item.unavailable}}disabled{{/if}}>
    <label for="model_{{key}}_{{../randomId}}" class="{{#if item.unavailable}}model-unavailable{{/if}}" data-id="{{key}}" data-speed="{{item.speed}}" data-mana="{{item.price}}"
        data-elo="{{item.elo}}">
        <!--img src="modules/cibola8/templates/assets/{{key}}.webp"-->
        <!--img src="modules/cibola8/templates/assets/cibolacoin.webp"-->
        <div class="flexrow stretch">
            <div class="flexcol stretch">
                <div>
                    {{item.name}}
                </div>
                <div>
                    {{#each item.tags as |tag|}}
                    <span class="cibola8-badge badge-{{tag}}">{{localize (cibolaConcat 'cibola8.badges.'
                        tag)}}</span>
                    {{/each}}
                </div>
            </div>
            <div class="flexcol centerText stretch manaheader">
                {{#if item.elo}}
                <div data-tooltip="cibola8.tooltip.perceivedElo" class="progressbar"
                    style="--width: {{item.elowidth}}" data-label="{{item.elo}}"></div>
                {{else}}
                <div>
                    <span class="cibola8-badge cibola8-badge--muted">{{localize 'cibola8.badges.noRating'}}</span>
                </div>
                {{/if}}
                {{{item.manaHtml}}}
                {{{item.timeHtml}}}
            </div>

        </div>
    </label>
    {{/each}}
</div>